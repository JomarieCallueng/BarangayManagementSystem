@model BarangayCMS.Areas.Staff.ViewModels.ResidentViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "~/Areas/Staff/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Resident Profile Master";
}

<div class="container-fluid p-0">
    <!-- Main Profile Card Container -->
    <div class="card border-0 shadow-sm rounded-3 p-5 bg-white mx-auto" style="max-width: 900px; margin-top: 2rem;">

        <!-- Header Section -->
        <div class="d-flex justify-content-between align-items-start border-bottom pb-4 mb-4">
            <div>
                <span class="badge bg-primary-subtle text-primary px-2 py-1 rounded small mb-2 fw-semibold">
                    <i class="bi bi-person-badge-fill me-1"></i> Citizen Identification Master
                </span>
                <h1 class="fw-bold m-0 text-dark" style="font-size: 2.2rem; letter-spacing: -0.5px;">
                    @Model.LastName, @Model.FirstName @Model.MiddleName
                </h1>
                <p class="text-muted small m-0 mt-1">
                    Registered in System: July 14, 2026
                </p>
            </div>
            <div>
                @if (Model.IsVoter)
                {
                    <span class="badge bg-success text-uppercase px-3 py-2 fw-bold tracking-wide" style="font-size: 0.8rem;">
                        Voter Record
                    </span>
                }
                else
                {
                    <span class="badge bg-secondary text-uppercase px-3 py-2 fw-bold tracking-wide" style="font-size: 0.8rem; background-color: #6c757d !important;">
                        Non-Voter Record
                    </span>
                }
            </div>
        </div>

        <!-- Meta Info Grid -->
        <div class="row g-4 mb-4">
            <!-- Gender -->
            <div class="col-md-4">
                <span class="text-uppercase text-secondary fw-semibold tracking-wider d-block mb-1" style="font-size: 0.75rem;">
                    Gender
                </span>
                <span class="fs-5 fw-medium text-dark">@Model.Gender</span>
            </div>

            <!-- Civil Status -->
            <div class="col-md-4">
                <span class="text-uppercase text-secondary fw-semibold tracking-wider d-block mb-1" style="font-size: 0.75rem;">
                    Civil Status
                </span>
                <span class="fs-5 fw-medium text-dark">@Model.CivilStatus</span>
            </div>

            <!-- Date of Birth -->
            <div class="col-md-4">
                <span class="text-uppercase text-secondary fw-semibold tracking-wider d-block mb-1" style="font-size: 0.75rem;">
                    Date of Birth
                </span>
                <span class="fs-5 fw-medium text-dark">
                    @(Model.BirthDate != default ? Model.BirthDate.ToString("MMMM dd, yyyy") : "Unspecified")
                </span>
            </div>

            <!-- Primary Mobile -->
            <div class="col-md-4">
                <span class="text-uppercase text-secondary fw-semibold tracking-wider d-block mb-1" style="font-size: 0.75rem;">
                    Primary Mobile
                </span>
                <span class="fs-5 fw-medium text-dark">
                    @(string.IsNullOrEmpty(Model.ContactNumber) ? "None" : Model.ContactNumber)
                </span>
            </div>

            <!-- Occupation / Employment -->
            <div class="col-md-8">
                <span class="text-uppercase text-secondary fw-semibold tracking-wider d-block mb-1" style="font-size: 0.75rem;">
                    Occupation / Employment
                </span>
                <span class="fs-5 fw-medium text-dark">Unspecified / None</span>
            </div>
        </div>

        <!-- Home Address Section -->
        <div class="mt-2">
            <span class="text-uppercase text-secondary fw-semibold tracking-wider d-block mb-2" style="font-size: 0.75rem;">
                Registered Home Address
            </span>
            <div class="p-3 bg-light rounded border border-light-subtle d-flex align-items-center">
                <i class="bi bi-geo-alt-fill text-secondary fs-5 me-3"></i>
                <span class="text-dark fw-medium">@Model.Address</span>
            </div>
        </div>

    </div>

    <!-- Bottom Action Navigation Buttons -->
    <div class="d-flex justify-content-between align-items-center mx-auto mt-4" style="max-width: 900px;">
        <!-- Back to List button -->
        <a asp-area="Staff" asp-controller="Residents" asp-action="Index" class="btn btn-outline-secondary px-4 py-2 fw-medium bg-white shadow-sm text-dark border-secondary-subtle">
            <i class="bi bi-arrow-left me-1"></i> Registry Ledger
        </a>

        <!-- Edit Profile button (Tuturol sa Edit action) -->
        <a asp-area="Staff" asp-controller="Residents" asp-action="Edit" asp-route-id="@Model.ResidentId" class="btn btn-primary px-4 py-2 fw-medium shadow-sm">
            <i class="bi bi-pencil-square me-1"></i> Modify Resident Profile
        </a>
    </div>
</div>