@model BarangayCMS.Areas.Staff.ViewModels.DisasterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Incident Details</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="container py-5" style="max-width: 700px;">
        <div class="card border-0 shadow-sm p-4 rounded-3 mb-3">
            <div class="border-bottom pb-3 mb-3 d-flex justify-content-between align-items-start">
                <div>
                    <span class="badge bg-warning bg-opacity-10 text-warning mb-2 px-2 py-1"><i class="bi bi-shield-exclamation"></i> Emergency Operation File</span>
                    <!-- 🆕 Ginamit ang Incident Name at inilagay sa ibaba ang Disaster Type -->
                    <h3 class="fw-bold text-dark mb-1">@Model.IncidentName</h3>
                    <span class="badge bg-secondary-subtle text-dark mb-2">@Model.DisasterType</span>
                    <br />
                    <!-- 🛠️ Binago mula DateOccurred -> OccurrenceDate -->
                    <small class="text-muted"><i class="bi bi-clock"></i> Reported: @Model.OccurrenceDate.ToString("F")</small>
                </div>
                <span class="badge @(Model.Status == "Active" ? "bg-danger text-danger" : "bg-success text-success") bg-opacity-10 border px-3 py-2 fs-6">
                    @Model.Status
                </span>
            </div>

            <div class="row g-3 mb-3 small">
                <div class="col-12">
                    <span class="text-muted d-block fw-bold mb-1">AFFECTED LOCATION</span>
                    <div class="p-2 bg-light border rounded text-secondary fw-semibold"><i class="bi bi-geo-alt-fill text-muted me-1"></i> @Model.Location</div>
                </div>
            </div>

            <div>
                <span class="text-muted small d-block fw-bold mb-1">SITUATION REPORT NARRATIVE</span>
                <p class="text-secondary p-3 border rounded bg-white" style="white-space: pre-line; line-height: 1.6; min-height: 120px;">@Model.Description</p>
            </div>
        </div>
        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3"><i class="bi bi-arrow-left"></i> Operations Back</a>
            <!-- 🛠️ Binago mula DisasterId -> Id para sa tamang routing -->
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-primary px-4"><i class="bi bi-pencil"></i> Modify Operations Log</a>
        </div>
    </div>
</body>
</html>