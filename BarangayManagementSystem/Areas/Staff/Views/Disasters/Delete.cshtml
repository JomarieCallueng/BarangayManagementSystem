@model BarangayCMS.Areas.Staff.ViewModels.DisasterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Delete Crisis Record</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="container py-5" style="max-width: 550px;">
        <div class="card border-0 shadow-sm p-4 rounded-3 border-top border-danger border-4">
            <div class="text-center text-danger mb-3">
                <i class="bi bi-trash3-fill fs-1"></i>
                <h5 class="fw-bold text-dark mt-2 mb-1">Tanggalin ang Incident Log na ito?</h5>
                <p class="text-muted small">Maaari lamang itong gawin kung mali ang pagkaka-encode upang maiwasan ang maling datos.</p>
            </div>

            <div class="bg-light p-3 rounded-2 mb-4 border small text-start">
                <!-- 🆕 Ipinapakita na rin ang Incident Name para mas malinaw -->
                <div class="mb-1"><strong>Incident Name:</strong> <span class="text-dark fw-semibold">@Model.IncidentName</span></div>
                <div class="mb-1"><strong>Incident Classification:</strong> <span class="text-secondary">@Model.DisasterType</span></div>
                <div><strong>Location Registered:</strong> <span class="text-secondary">@Model.Location</span></div>
            </div>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()

                <!-- 🛠️ Binago mula DisasterId -> Id para tumugma sa updated ViewModel -->
                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-center gap-2">
                    <a asp-action="Index" class="btn btn-sm btn-light border px-4">Cancel</a>
                    <button type="submit" class="btn btn-sm btn-danger px-4 fw-semibold">Confirm Void Record</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>