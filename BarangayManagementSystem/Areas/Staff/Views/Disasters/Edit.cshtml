@model BarangayCMS.Areas.Staff.ViewModels.DisasterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Modify Operations Log</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="container py-5" style="max-width: 700px;">
        <div class="card border-0 shadow-sm p-4 rounded-3">
            <div class="border-bottom pb-3 mb-4">
                <span class="badge bg-primary bg-opacity-10 text-primary mb-2 px-2 py-1"><i class="bi bi-pencil-square"></i> Update Emergency Operation File</span>
                <h3 class="fw-bold text-dark mb-1">Modify Operations Log</h3>
                <p class="text-muted small mb-0">I-update ang kasalukuyang sitwasyon, bilang ng apektadong residente, at estado ng operasyon.</p>
            </div>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()

                <!-- 🛠️ Tumuturo na sa tamang 'Id' property -->
                <input type="hidden" asp-for="Id" />

                <div class="row g-3 mb-3">
                    <!-- Incident Name -->
                    <div class="col-12">
                        <label asp-for="IncidentName" class="form-label small fw-bold text-secondary">Incident / Calamity Name</label>
                        <input asp-for="IncidentName" class="form-control form-control-sm" placeholder="e.g., Super Typhoon Egay" />
                        <span asp-validation-for="IncidentName" class="text-danger small"></span>
                    </div>

                    <!-- Disaster Type -->
                    <div class="col-md-6">
                        <label asp-for="DisasterType" class="form-label small fw-bold text-secondary">Disaster / Incident Type</label>
                        <input asp-for="DisasterType" class="form-control form-control-sm" placeholder="e.g., Typhoon Flooding" />
                        <span asp-validation-for="DisasterType" class="text-danger small"></span>
                    </div>

                    <!-- Occurrence Date -->
                    <div class="col-md-6">
                        <label asp-for="OccurrenceDate" class="form-label small fw-bold text-secondary">Date & Time Occurred</label>
                        <input asp-for="OccurrenceDate" class="form-control form-control-sm" type="datetime-local" />
                        <span asp-validation-for="OccurrenceDate" class="text-danger small"></span>
                    </div>

                    <!-- Location -->
                    <div class="col-12">
                        <label asp-for="Location" class="form-label small fw-bold text-secondary">Affected Location / Area</label>
                        <input asp-for="Location" class="form-control form-control-sm" placeholder="e.g., Purok 3 (Riverside)" />
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>
                </div>

                <hr class="text-muted opacity-25my-4" />

                <!-- 📊 Impact & Tracking Stats Group -->
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="AffectedHouseholdsCount" class="form-label small fw-bold text-secondary">Affected Households (HH)</label>
                        <input asp-for="AffectedHouseholdsCount" class="form-control form-control-sm" type="number" min="0" />
                        <span asp-validation-for="AffectedHouseholdsCount" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="DisplacedIndividualsCount" class="form-label small fw-bold text-secondary">Displaced Individuals (Pax)</label>
                        <input asp-for="DisplacedIndividualsCount" class="form-control form-control-sm" type="number" min="0" />
                        <span asp-validation-for="DisplacedIndividualsCount" class="text-danger small"></span>
                    </div>

                    <!-- Evacuation Center Status Dropdown -->
                    <div class="col-md-4">
                        <label asp-for="EvacuationCenterStatus" class="form-label small fw-bold text-secondary">Evac Center Status</label>
                        <select asp-for="EvacuationCenterStatus" class="form-select form-select-sm">
                            <option value="Closed">Closed</option>
                            <option value="Open">Open</option>
                        </select>
                        <span asp-validation-for="EvacuationCenterStatus" class="text-danger small"></span>
                    </div>

                    <!-- Relief Distribution Status Dropdown -->
                    <div class="col-md-4">
                        <label asp-for="ReliefDistributionStatus" class="form-label small fw-bold text-secondary">Relief Distribution</label>
                        <select asp-for="ReliefDistributionStatus" class="form-select form-select-sm">
                            <option value="Ongoing">Ongoing</option>
                            <option value="Completed">Completed</option>
                        </select>
                        <span asp-validation-for="ReliefDistributionStatus" class="text-danger small"></span>
                    </div>

                    <!-- Overall Record Status (Active/Resolved) -->
                    <div class="col-md-4">
                        <label asp-for="Status" class="form-label small fw-bold text-secondary">Operational Status</label>
                        <select asp-for="Status" class="form-select form-select-sm">
                            <option value="Active">Active</option>
                            <option value="Resolved">Resolved</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Situation Narrative -->
                <div class="mb-4">
                    <label asp-for="Description" class="form-label small fw-bold text-secondary">Situation Report Narrative</label>
                    <textarea asp-for="Description" class="form-control form-control-sm" rows="4" placeholder="Ilarawan ang kasalukuyang sitwasyon o lawak ng pinsala..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <!-- Form Actions -->
                <div class="d-flex justify-content-between border-top pt-3">
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3"><i class="bi bi-arrow-left"></i> Cancel</a>
                    <button type="submit" class="btn btn-sm btn-primary px-4 fw-semibold"><i class="bi bi-save"></i> Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>