@model BarangayCMS.Areas.Staff.ViewModels.ComplaintViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Edit Complaint Log</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container py-5" style="max-width: 650px;">
        <div class="card border-0 shadow-sm p-4 rounded-3">
            <h5 class="fw-bold text-dark mb-1">Update Complaint & Status</h5>
            <p class="text-muted small mb-4">Baguhin ang mga detalye o i-update ang estado ng pagdinig/blotter.</p>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ComplaintId" />
                <input type="hidden" asp-for="ResidentId" />
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">Complainant</label>
                    <input class="form-control form-control-sm bg-light" value="@Model.ResidentName" readonly />
                </div>
                <div class="mb-3">
                    <label asp-for="Subject" class="form-label small fw-bold text-secondary"></label>
                    <input asp-for="Subject" class="form-control form-control-sm" />
                    <span asp-validation-for="Subject" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Description" class="form-label small fw-bold text-secondary"></label>
                    <textarea asp-for="Description" class="form-control form-control-sm" rows="5"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Status" class="form-label small fw-bold text-secondary">Blotter Case Status</label>
                    <select asp-for="Status" class="form-select form-select-sm">
                        <option value="Pending">Pending (Bago / Hindi pa Naaksyunan)</option>
                        <option value="Ongoing">Ongoing (Kasalukuyang Dinidinig)</option>
                        <option value="Resolved">Resolved (Naayos / Sarado na)</option>
                    </select>
                </div>
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-sm btn-light border px-3">Discard</a>
                    <button type="submit" class="btn btn-sm btn-primary px-4">Save Updates</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>