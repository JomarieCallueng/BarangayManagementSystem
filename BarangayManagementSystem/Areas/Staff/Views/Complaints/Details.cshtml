@model BarangayCMS.Areas.Staff.ViewModels.ComplaintViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Complaint Details</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="container py-5" style="max-width: 700px;">
        <div class="card border-0 shadow-sm p-4 rounded-3 mb-3">
            <div class="border-bottom pb-3 mb-3 d-flex justify-content-between align-items-start">
                <div>
                    <span class="badge bg-danger bg-opacity-10 text-danger mb-2 px-2 py-1"><i class="bi bi-shield-exclamation"></i> Blotter Case #@Model.ComplaintId</span>
                    <h3 class="fw-bold text-dark mb-1">@Model.Subject</h3>
                    <small class="text-muted"><i class="bi bi-calendar-event"></i> Logged Date: @Model.DateSubmitted.ToString("F")</small>
                </div>
                <span class="badge @(Model.Status == "Resolved" ? "bg-success text-success" : "bg-warning text-warning") bg-opacity-10 border px-3 py-2 fs-6">
                    @Model.Status
                </span>
            </div>

            <div class="mb-4">
                <span class="text-muted small d-block mb-1 fw-bold">COMPLAINANT (NAGREREKLAMO)</span>
                <div class="p-2 bg-light border rounded fw-semibold text-secondary"><i class="bi bi-person-fill text-muted me-1"></i> @Model.ResidentName</div>
            </div>

            <div>
                <span class="text-muted small d-block mb-1 fw-bold">INCIDENT DESCRIPTION</span>
                <p class="text-secondary p-3 border rounded bg-white" style="white-space: pre-line; line-height: 1.6; min-height: 150px;">@Model.Description</p>
            </div>
        </div>
        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3"><i class="bi bi-arrow-left"></i> Back to Logs</a>
            <a asp-action="Edit" asp-route-id="@Model.ComplaintId" class="btn btn-sm btn-primary px-4"><i class="bi bi-pencil"></i> Manage Case</a>
        </div>
    </div>
</body>
</html>