@model IEnumerable<BarangayCMS.Areas.Staff.ViewModels.ComplaintViewModel>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "~/Areas/Staff/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Complaints Ledger";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <span class="text-muted small">Dashboard</span>
            <h2 class="fw-bold m-0 text-dark" style="font-size: 1.5rem;">Complaints & Blotter Ledger</h2>
        </div>
        <div>
            <a asp-area="Staff" asp-controller="Complaints" asp-action="Create" class="btn btn-danger fw-semibold px-4 shadow-sm">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>File New Complaint
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 p-4 bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr class="text-uppercase tracking-wider text-secondary" style="font-size: 0.75rem; font-weight: 600;">
                        <th>Case / Blotter No.</th>
                        <th>Complainant Name</th>
                        <th>Incident Details</th>
                        <th>Date Submitted</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-muted small fw-mono fw-bold">
                                    @(string.IsNullOrEmpty(item.Subject) ? $"#C-{item.ComplaintId.ToString("D4")}" : item.Subject)
                                </td>
                                <td class="fw-semibold text-dark">
                                    @item.ResidentName
                                </td>
                                <td>
                                    <small class="text-muted text-truncate d-inline-block" style="max-width: 300px;">
                                        @item.Description
                                    </small>
                                </td>
                                <td>
                                    @item.DateSubmitted.ToString("MM/dd/yyyy hh:mm tt")
                                </td>
                                <td>
                                    @if (item.Status == "Resolved")
                                    {
                                        <span class="badge bg-success-subtle text-success px-2 py-1 rounded">@item.Status</span>
                                    }
                                    else if (item.Status == "Dismissed")
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary px-2 py-1 rounded">@item.Status</span>
                                    }
                                    else if (item.Status == "Scheduled for Mediation")
                                    {
                                        <span class="badge bg-info-subtle text-info px-2 py-1 rounded">@item.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning px-2 py-1 rounded">@item.Status</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end align-items-center gap-1">
                                        <a asp-area="Staff" asp-controller="Complaints" asp-action="Details" asp-route-id="@item.ComplaintId" class="btn btn-sm btn-outline-secondary px-2">
                                            View
                                        </a>

                                        <a asp-area="Staff" asp-controller="Complaints" asp-action="Edit" asp-route-id="@item.ComplaintId" class="btn btn-sm btn-outline-primary px-2">
                                            Edit
                                        </a>

                                        @if (item.Status != "Dismissed" && item.Status != "Resolved")
                                        {
                                            <!-- DISMISS FORM (Alternatibo sa Delete para magbago ang status sa DB) -->
                                            <form asp-area="Staff" asp-controller="Complaints" asp-action="Dismiss" asp-route-id="@item.ComplaintId" method="post" class="m-0 p-0 d-inline" onsubmit="return confirm('Sigurado ka bang nais mong i-Dismiss/Ibasura ang sumbong na ito?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger px-2">
                                                    Dismiss
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted small">
                                Walang nakitang rekord sa database ng Barangay.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>