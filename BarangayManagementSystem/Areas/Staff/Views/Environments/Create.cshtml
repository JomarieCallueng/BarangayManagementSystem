@model BarangayCMS.Areas.Staff.ViewModels.EnvironmentViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Create Activity Log</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container py-5" style="max-width: 650px;">
        <div class="card border-0 shadow-sm p-4 rounded-3">
            <h5 class="fw-bold text-dark mb-1">New Environmental Action Intake</h5>
            <p class="text-muted small mb-4">I-rekord ang darating o natapos na proyektong pang-komunidad para sa kalikasan.</p>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label asp-for="ActivityName" class="form-label small fw-bold text-secondary"></label>
                    <input asp-for="ActivityName" class="form-control form-control-sm" placeholder="e.g., Coastal Clean-up, Waste Segregation Seminar" />
                    <span asp-validation-for="ActivityName" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Location" class="form-label small fw-bold text-secondary"></label>
                    <input asp-for="Location" class="form-control form-control-sm" placeholder="Saan gaganapin ang aktibidad..." />
                    <span asp-validation-for="Location" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ActivityDate" class="form-label small fw-bold text-secondary"></label>
                    <input asp-for="ActivityDate" class="form-control form-control-sm" type="datetime-local" />
                    <span asp-validation-for="ActivityDate" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Description" class="form-label small fw-bold text-secondary"></label>
                    <textarea asp-for="Description" class="form-control form-control-sm" rows="4" placeholder="Ilista ang layunin, mga kasosyong organisasyon, o detalye ng aktibidad..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-sm btn-light border px-3">Cancel</a>
                    <button type="submit" class="btn btn-sm btn-success px-4 fw-bold">Save Eco Log</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>