@model BarangayCMS.Areas.Staff.ViewModels.EnvironmentViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Edit Eco Record</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container py-5" style="max-width: 650px;">
        <div class="card border-0 shadow-sm p-4 rounded-3">
            <h5 class="fw-bold text-dark mb-1">Modify Activity Profile</h5>
            <p class="text-muted small mb-4">I-update ang iskedyul, lokasyon, o deskripsyon ng proyektong pang-kapaligiran.</p>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="EnvironmentRecordId" />
                <div class="mb-3">
                    <label asp-for="ActivityName" class="form-label small fw-bold text-secondary"></label>
                    <input asp-for="ActivityName" class="form-control form-control-sm" />
                    <span asp-validation-for="ActivityName" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Location" class="form-label small fw-bold text-secondary"></label>
                    <input asp-for="Location" class="form-control form-control-sm" />
                    <span asp-validation-for="Location" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ActivityDate" class="form-label small fw-bold text-secondary"></label>
                    <input asp-for="ActivityDate" class="form-control form-control-sm" type="datetime-local" />
                    <span asp-validation-for="ActivityDate" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Description" class="form-label small fw-bold text-secondary"></label>
                    <textarea asp-for="Description" class="form-control form-control-sm" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-sm btn-light border px-3">Discard Changes</a>
                    <button type="submit" class="btn btn-sm btn-primary px-4">Update Record</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>