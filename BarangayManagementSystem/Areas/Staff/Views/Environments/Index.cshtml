@model IEnumerable<BarangayCMS.Areas.Staff.ViewModels.EnvironmentViewModel>
@{
    Layout = "~/Areas/Staff/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Environment & Cleanliness";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <small class="text-muted text-uppercase fw-bold">SANITATION</small>
        <h2 class="fw-bold text-dark m-0"><i class="bi bi-tree-fill text-success me-2"></i>Environment & Cleanliness</h2>
        <p class="text-muted small mb-0">Manage community cleanup drives, waste tracking, and sanitation profiling.</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-sm btn-success fw-semibold px-4 shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Plan Cleanup Drive
        </a>
    </div>
</div>

<!-- Ang Puting Card wrapper na may laman nang Tables -->
<div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary small fw-bold">
                    <tr>
                        <th class="ps-4 py-3">Project / Activity Name</th>
                        <th class="py-3">Target Location</th>
                        <th class="py-3">Schedule Date</th>
                        <th class="py-3">Description Snippet</th>
                        <th class="text-end p-4 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody class="small">
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-trash2 display-6 d-block mb-2 text-secondary"></i>
                                Walang nakatalang aktibidad para sa kalinisan sa kasalukuyan.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-dark">@item.ActivityName</td>
                                <td class="text-secondary">@item.Location</td>
                                <td class="text-secondary">@item.ActivityDate.ToString("MMMM dd, yyyy")</td>
                                <td class="text-muted text-truncate" style="max-width: 250px;">@item.Description</td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-1">
                                        <a asp-action="Details" asp-route-id="@item.EnvironmentRecordId" class="btn btn-sm btn-light border px-2">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.EnvironmentRecordId" class="btn btn-sm btn-outline-primary px-2">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>