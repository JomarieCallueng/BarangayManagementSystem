@model BarangayCMS.Areas.Staff.ViewModels.AnnouncementViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Edit Announcement</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container py-5" style="max-width: 650px;">
        <div class="card border-0 shadow-sm p-4 rounded-3">
            <h5 class="fw-bold text-dark mb-1">Modify Announcement</h5>
            <p class="text-muted small mb-4">Baguhin o iwasto ang impormasyon sa ibaba.</p>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="AnnouncementId" />
                <div class="mb-3">
                    <label asp-for="Title" class="form-label small fw-bold text-secondary"></label>
                    <input asp-for="Title" class="form-control form-control-sm" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Content" class="form-label small fw-bold text-secondary"></label>
                    <textarea asp-for="Content" class="form-control form-control-sm" rows="6"></textarea>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                </div>
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-sm btn-light border px-3">Discard</a>
                    <button type="submit" class="btn btn-sm btn-success px-4">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>