@model BarangayCMS.Areas.Staff.ViewModels.AnnouncementViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Announcement Details</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="container py-5" style="max-width: 700px;">
        <div class="card border-0 shadow-sm p-4 rounded-3 mb-3">
            <div class="border-bottom pb-3 mb-3">
                <span class="badge bg-info bg-opacity-10 text-info mb-2 px-2 py-1"><i class="bi bi-info-circle"></i> Official Board Post</span>
                <h3 class="fw-bold text-dark mb-1">@Model.Title</h3>
                <small class="text-muted"><i class="bi bi-clock"></i> Posted on @Model.DatePosted.ToString("F")</small>
            </div>

            <p class="text-secondary style" style="white-space: pre-line; line-height: 1.6;">@Model.Content</p>
        </div>
        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3"><i class="bi bi-arrow-left"></i> Back to List</a>
            <a asp-action="Edit" asp-route-id="@Model.AnnouncementId" class="btn btn-sm btn-primary px-4"><i class="bi bi-pencil"></i> Edit Post</a>
        </div>
    </div>
</body>
</html>