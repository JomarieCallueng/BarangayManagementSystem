@model IEnumerable<BarangayCMS.Areas.Staff.ViewModels.AnnouncementViewModel>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "~/Areas/Staff/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Barangay Bulletins & Announcements";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <small class="text-muted text-uppercase fw-bold">Information</small>
        <h2 class="fw-bold text-dark m-0"><i class="bi bi-megaphone-fill text-primary me-2"></i>Public Announcements</h2>
        <p class="text-muted small mb-0">Publish official notices, community events, and advisory details.</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary fw-semibold px-4 shadow-sm">
            <i class="bi bi-pencil-square me-1"></i> Compose Post
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary small fw-bold">
                    <tr>
                        <th class="ps-4 py-3">Bulletin Title</th>
                        <th class="py-3">Category</th>
                        <th class="py-3">Author</th>
                        <th class="py-3">Publish Date</th>
                        <th class="py-3">Status</th>
                        <th class="text-end pe-4 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody class="small">
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                <i class="bi bi-clipboard-x display-6 d-block mb-2 text-secondary"></i>
                                Walang kasalukuyang anunsyo o advisory na naka-post.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-dark">
                                    @if (item.IsPinned)
                                    {
                                        <i class="bi bi-pin-angle-fill text-danger me-1" title="Pinned Post"></i>
                                    }
                                    @item.Title
                                </td>
                                <td>
                                    <span class="badge bg-blue-subtle text-primary px-2.5 py-1.5 rounded fw-medium">
                                        @item.Category
                                    </span>
                                </td>
                                <td class="text-secondary">@item.AuthorName</td>
                                <td class="text-secondary">@item.PublishDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    @if (item.ExpiryDate.HasValue && item.ExpiryDate.Value < DateTime.Today)
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary px-2.5 py-1.5 rounded fw-medium">Expired</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success px-2.5 py-1.5 rounded fw-medium">Active</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary border-secondary-subtle" title="Edit Post">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger border-secondary-subtle" title="Remove Post">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-blue-subtle {
        background-color: #e7f1ff;
    }

    .bg-success-subtle {
        background-color: #e6f6ec;
    }

    .bg-secondary-subtle {
        background-color: #f1f3f5;
    }
</style>