@model BarangayCMS.Areas.Staff.ViewModels.AnnouncementViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Remove Announcement</title>
    <link class="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link class="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="container py-5" style="max-width: 550px;">
        <div class="card border-0 shadow-sm p-4 rounded-3 border-top border-danger border-4">
            <div class="text-center text-danger mb-3">
                <i class="bi bi-exclamation-triangle-fill fs-1"></i>
                <h5 class="fw-bold text-dark mt-2 mb-1">Sigurado ka ba na nais mong burahin ito?</h5>
                <p class="text-muted small">Ang aksyong ito ay permanente at hindi na pwedeng bawiin.</p>
            </div>

            <div class="bg-light p-3 rounded-2 mb-4 text-center border">
                <span class="small text-muted d-block text-uppercase fw-bold">Target Post Title</span>
                <span class="fw-bold text-secondary">"@Model.Title"</span>
            </div>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="AnnouncementId" />
                <div class="d-flex justify-content-center gap-2">
                    <a asp-action="Index" class="btn btn-sm btn-light border px-4">Cancel</a>
                    <button type="submit" class="btn btn-sm btn-danger px-4 fw-semibold">Yes, Delete Post</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>