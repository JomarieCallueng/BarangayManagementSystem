@model BarangayCMS.Areas.Staff.ViewModels.ReportsViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "~/Areas/Staff/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.ReportTitle;
}

<div class="container-fluid" id="report-print-area">
    <!-- Header Area (Ito ang lalabas sa PDF) -->
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="fw-bold text-dark m-0"><i class="bi bi-file-earmark-bar-graph text-primary me-2"></i>@Model.ReportTitle</h2>
            <p class="text-muted small mb-0">Generated on: @Model.GeneratedDate.ToString("MMMM dd, yyyy hh:mm tt")</p>
        </div>
        <!-- Actions Button (Naka-hide kapag nagprint) -->
        <div class="btn-group shadow-sm no-print">
            <a asp-area="Staff" asp-controller="Reports" asp-action="Index" class="btn btn-outline-secondary btn-sm fw-semibold">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
            <button type="button" onclick="window.print()" class="btn btn-danger btn-sm fw-semibold">
                <i class="bi bi-file-earmark-pdf-fill me-1"></i> Export PDF / Print
            </button>

            <!-- 🚀 INAYOS: Diretso na ito sa Server-Side Controller Action para garantisadong mag-download gamit ang bagong engine -->
            <a asp-area="Staff" asp-controller="Reports" asp-action="ExportReportToExcel" asp-route-reportType="Residents" class="btn btn-success btn-sm fw-semibold">
                <i class="bi bi-file-earmark-excel-fill me-1"></i> Export Excel
            </a>
        </div>
    </div>

    <!-- Summary Widgets (Kasama pa rin sa Report) -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="p-3 bg-light border rounded-3">
                <small class="text-uppercase text-muted fw-bold d-block" style="font-size: 0.7rem;">Total Residents In System</small>
                <h4 class="fw-bold m-0 text-primary">@Model.TotalResidents</h4>
            </div>
        </div>
    </div>

    <!-- 📊 ANG TUNAY NA DATATABLE -->
    <div class="card border-0 shadow-sm rounded-3">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0" id="residents-table">
                <thead class="table-dark">
                    <tr>
                        <th>Resident ID</th>
                        <th>Full Name</th>
                        <th>Age</th>
                        <th>Voter Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.TableData != null && Model.TableData.Any())
                    {
                        foreach (var row in Model.TableData)
                        {
                            <tr>
                                <!-- 🔑 INAYOS: Tugma na ang mga Keys sa iniluluwas ng bagong Controller Data Helpers -->
                                <td><strong>@row["Resident ID"]</strong></td>
                                <td>@row["Full Name"]</td>
                                <td>@row["Age"]</td>
                                <td>
                                    <span class="badge bg-success">@row["Voter Status"]</span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">No records found for this period.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* 🖨️ CSS PRINT UTILITY */
    @@media print {
        .no-print, nav, .sidebar, header, .navbar, .btn-group, a, .btn {
            display: none !important;
        }

        main, .main-content, .content-body, .container-fluid {
            margin-left: 0 !important;
            margin-right: 0 !important;
            padding: 0 !important;
            width: 100% !important;
        }

        .table {
            width: 100% !important;
            border-collapse: collapse !important;
        }

            .table th {
                background-color: #212529 !important;
                color: white !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
    }
</style>