@model BarangayCMS.Areas.Staff.ViewModels.ReportsViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "~/Areas/Staff/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Staff Analytical Reports";
}

<!-- 🔴 RED HOVER EFFECT STYLE -->
<style>
    .btn-export-pdf {
        background-color: #212529; /* Dati nitong kulay (Itim/Dark) */
        color: #ffffff;
        border: 1px solid #212529;
        transition: all 0.3s ease;
    }

        /* Magiging Kulay Pula kapag itinutok ang cursor/arrow */
        .btn-export-pdf:hover {
            background-color: #dc3545 !important; /* Red */
            border-color: #dc3545 !important;
            color: #ffffff !important;
            box-shadow: 0 4px 10px rgba(220, 53, 69, 0.35); /* Red Glow Effect */
        }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark mb-1">
            <i class="bi bi-graph-up-arrow me-2" style="color: #6b46c1;"></i>Reports Engine (Staff)
        </h2>
        <p class="text-muted small mb-0">Compile demographic, safety incidents, and general transaction report datasets.</p>
    </div>

    <!-- 🔴 UPDATE: PINALITAN ANG CLASS NG btn-export-pdf -->
    <a asp-area="Staff" asp-controller="Reports" asp-action="Export" class="btn btn-export-pdf shadow-sm">
        <i class="bi bi-download me-1"></i> Export PDF Summary
    </a>
</div>

<!-- MGA ANALYTICAL COUNTERS -->
<div class="row g-3 mb-4">
    <!-- Residents -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 bg-white h-100">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-muted small uppercase mb-1">Total Residents</h6>
                    <h3 class="fw-bold text-dark mb-0">@Model.TotalResidents</h3>
                </div>
                <div class="bg-light p-2 rounded text-primary">
                    <i class="bi bi-people-fill fs-4"></i>
                </div>
            </div>
            <a asp-area="Staff" asp-controller="Reports" asp-action="Residents" class="text-decoration-none small text-primary mt-3 d-block">
                View Dataset <i class="bi bi-arrow-right-short"></i>
            </a>
        </div>
    </div>

    <!-- Certificates -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 bg-white h-100">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-muted small uppercase mb-1">Certificates Issued</h6>
                    <h3 class="fw-bold text-dark mb-0">@Model.TotalCertificatesIssued</h3>
                </div>
                <div class="bg-light p-2 rounded text-info">
                    <i class="bi bi-file-earmark-text-fill fs-4"></i>
                </div>
            </div>
            <a asp-area="Staff" asp-controller="Reports" asp-action="Certificates" class="text-decoration-none small text-info mt-3 d-block">
                View Dataset <i class="bi bi-arrow-right-short"></i>
            </a>
        </div>
    </div>

    <!-- Complaints -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 bg-white h-100">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-muted small uppercase mb-1">Active Complaints</h6>
                    <h3 class="fw-bold text-dark mb-0">@Model.ActiveComplaints</h3>
                </div>
                <div class="bg-light p-2 rounded text-danger">
                    <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                </div>
            </div>
            <a asp-area="Staff" asp-controller="Reports" asp-action="Complaints" class="text-decoration-none small text-danger mt-3 d-block">
                View Dataset <i class="bi bi-arrow-right-short"></i>
            </a>
        </div>
    </div>

    <!-- Disasters -->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 bg-white h-100">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-muted small uppercase mb-1">Active Disasters</h6>
                    <h3 class="fw-bold text-dark mb-0">@Model.ActiveDisasters</h3>
                </div>
                <div class="bg-light p-2 rounded text-warning">
                    <i class="bi bi-shield-exclamation fs-4"></i>
                </div>
            </div>
            <a asp-area="Staff" asp-controller="Reports" asp-action="Disaster" class="text-decoration-none small text-warning mt-3 d-block">
                View Dataset <i class="bi bi-arrow-right-short"></i>
            </a>
        </div>
    </div>
</div>

<!-- SUB-MODULE LINKS -->
<div class="card border-0 shadow-sm rounded p-4 mb-4">
    <h5 class="fw-bold text-dark mb-3">Analytical Matrix Datasets</h5>
    <div class="row row-cols-1 row-cols-md-3 g-2">
        <div class="col">
            <a asp-area="Staff" asp-controller="Reports" asp-action="Environment" class="btn btn-outline-secondary w-100 text-start py-2">
                <i class="bi bi-tree me-2"></i> Ecological & Environment Logs
            </a>
        </div>
        <div class="col">
            <a asp-area="Staff" asp-controller="Reports" asp-action="Health" class="btn btn-outline-secondary w-100 text-start py-2">
                <i class="bi bi-heart-pulse me-2"></i> Health Center Summary Logs
            </a>
        </div>
    </div>
</div>

<!-- READY CARD -->
<div class="card border-0 shadow-sm rounded p-4 text-center py-5 bg-white">
    <div class="text-muted">
        <i class="bi bi-bar-chart-line display-4 text-secondary"></i>
        <h5 class="mt-3 fw-bold text-dark">Ready for Aggregation (Staff Mode)</h5>
        <p class="small text-muted mb-0">Maaari mong piliin ang mga dataset sa itaas o i-click ang <strong>Export PDF Summary</strong> para sa pangkalahatang ulat.</p>
    </div>
</div>