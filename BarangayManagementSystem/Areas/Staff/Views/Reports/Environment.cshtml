@model BarangayCMS.Areas.Staff.ViewModels.ReportsViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "~/Areas/Staff/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.ReportTitle;
}

<div class="container-fluid" id="report-print-area">
    <!-- Header Area -->
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="fw-bold text-dark m-0"><i class="bi bi-tree-fill text-success me-2"></i>@Model.ReportTitle</h2>
            <p class="text-muted small mb-0">Generated on: @Model.GeneratedDate.ToString("MMMM dd, yyyy hh:mm tt")</p>
        </div>
        <div class="btn-group shadow-sm no-print">
            <a asp-area="Staff" asp-controller="Reports" asp-action="Index" class="btn btn-outline-secondary btn-sm fw-semibold">
                <i class="bi bi-arrow-left"></i> Back
            </a>
            <button type="button" onclick="window.print()" class="btn btn-danger btn-sm fw-semibold">
                <i class="bi bi-file-earmark-pdf-fill me-1"></i> Export PDF / Print
            </button>
            <!-- Server-side Excel Exporter Link -->
            <a asp-area="Staff" asp-controller="Reports" asp-action="ExportReportToExcel" asp-route-reportType="Environment" class="btn btn-success btn-sm fw-semibold">
                <i class="bi bi-file-earmark-excel-fill me-1"></i> Export Excel
            </a>
        </div>
    </div>

    <!-- 📊 ENVIRONMENTAL ACTIVITIES DATATABLE -->
    <div class="card border-0 shadow-sm rounded-3">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0" id="env-table">
                <thead class="table-dark">
                    <tr>
                        <th>Activity ID</th>
                        <th>Environmental Activity</th>
                        <th>Venue / Area</th>
                        <th>Schedule Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.TableData != null && Model.TableData.Any())
                    {
                        foreach (var row in Model.TableData)
                        {
                            <tr>
                                <!-- Inayos ang Keys base sa Dictionary na galing sa controller helper -->
                                <td><strong>@row["Activity ID"]</strong></td>
                                <td>@row["Environmental Activity"]</td>
                                <td>@row["Venue / Area"]</td>
                                <td>@row["Schedule Date"]</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">No ecological activities recorded.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* 🖨️ CSS PRINT UTILITY */
    @@media print {
        .no-print, nav, .sidebar, header, .navbar, .btn-group, a, .btn {
            display: none !important;
        }

        main, .main-content, .content-body, .container-fluid {
            margin-left: 0 !important;
            margin-right: 0 !important;
            padding: 0 !important;
            width: 100% !important;
        }

        .table {
            width: 100% !important;
            border-collapse: collapse !important;
        }

            .table th {
                background-color: #212529 !important;
                color: white !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
    }
</style>