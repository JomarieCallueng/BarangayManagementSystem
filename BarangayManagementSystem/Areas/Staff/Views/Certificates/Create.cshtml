@model BarangayCMS.Areas.Staff.ViewModels.CertificateViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "~/Areas/Staff/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Issue New Certificate";
}

<div class="container-fluid p-0">
    <div class="card border-0 shadow-sm rounded-3 p-5 bg-white mx-auto" style="max-width: 800px; margin-top: 2rem;">

        <div class="border-bottom pb-3 mb-4">
            <h2 class="fw-bold text-dark m-0" style="font-size: 1.6rem;">
                <i class="bi bi-file-earmark-plus text-primary me-2"></i>Issue New Certificate
            </h2>
            <p class="text-muted small m-0 mt-1">Mag-isyu o mag-record ng bagong sertipiko para sa residente.</p>
        </div>

        <form asp-area="Staff" asp-controller="Certificates" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <!-- Select Resident -->
                <div class="col-md-12">
                    <label asp-for="ResidentId" class="form-label small fw-semibold text-secondary">Select Resident</label>
                    <select asp-for="ResidentId" asp-items="ViewBag.ResidentsList" class="form-select" required>
                        <option value="">-- Pumili ng Residente --</option>
                    </select>
                    <span asp-validation-for="ResidentId" class="text-danger small"></span>
                </div>

                <!-- Certificate Type -->
                <div class="col-md-6">
                    <label asp-for="CertificateType" class="form-label small fw-semibold text-secondary">Certificate Type</label>
                    <select asp-for="CertificateType" class="form-select" required>
                        <option value="">-- Uri ng Sertipiko --</option>
                        <option value="Barangay Clearance">Barangay Clearance</option>
                        <option value="Certificate of Indigency">Certificate of Indigency</option>
                        <option value="Certificate of Residency">Certificate of Residency</option>
                        <option value="Business Permit Clearance">Business Permit Clearance</option>
                    </select>
                    <span asp-validation-for="CertificateType" class="text-danger small"></span>
                </div>

                <!-- Status -->
                <div class="col-md-6">
                    <label asp-for="Status" class="form-label small fw-semibold text-secondary">Initial Status</label>
                    <select asp-for="Status" class="form-select" required>
                        <option value="Pending">Pending</option>
                        <option value="Approved">Approved</option>
                        <option value="Issued">Issued</option>
                    </select>
                </div>

                <!-- Amount Paid / Fee -->
                <div class="col-md-6">
                    <label asp-for="AmountPaid" class="form-label small fw-semibold text-secondary">Fee Paid (₱)</label>
                    <input asp-for="AmountPaid" type="number" step="0.01" class="form-control" value="0.00" required />
                </div>

                <!-- Official Receipt Number -->
                <div class="col-md-6">
                    <label asp-for="OfficialReceiptNumber" class="form-label small fw-semibold text-secondary">O.R. Number</label>
                    <input asp-for="OfficialReceiptNumber" class="form-control" placeholder="Optional" />
                </div>

                <!-- Purpose -->
                <div class="col-12">
                    <label asp-for="Purpose" class="form-label small fw-semibold text-secondary">Purpose / Reason</label>
                    <textarea asp-for="Purpose" class="form-control" rows="3" placeholder="Halimbawa: Local Employment, Financial Assistance, atbp." required></textarea>
                    <span asp-validation-for="Purpose" class="text-danger small"></span>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    Cancel
                </a>
                <button type="submit" class="btn btn-primary px-4 fw-semibold">
                    Generate Certificate
                </button>
            </div>
        </form>
    </div>
</div>