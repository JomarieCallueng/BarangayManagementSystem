@model BarangayCMS.Areas.Staff.ViewModels.CertificateViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Update Status</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container py-5" style="max-width: 600px;">
        <div class="card border-0 shadow-sm p-4 rounded-3">
            <h5 class="fw-bold text-dark mb-1">Update Request & Issuance</h5>
            <p class="text-muted small mb-4">Maaari mong palitan ang uri ng dokumento o baguhin ang status nito para maprint.</p>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="CertificateId" />
                <div class="mb-3">
                    <label asp-for="ResidentId" class="form-label small fw-bold text-secondary"></label>
                    <select asp-for="ResidentId" class="form-select form-select-sm" asp-items="ViewBag.ResidentsList"></select>
                </div>
                <div class="mb-3">
                    <label asp-for="CertificateType" class="form-label small fw-bold text-secondary"></label>
                    <select asp-for="CertificateType" class="form-select form-select-sm">
                        <option value="Barangay Clearance">Barangay Clearance</option>
                        <option value="Certificate of Indigency">Certificate of Indigency</option>
                        <option value="Certificate of Residency">Certificate of Residency</option>
                        <option value="Business Permit Clearance">Business Permit Clearance</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label asp-for="Status" class="form-label small fw-bold text-secondary">Document Status</label>
                    <select asp-for="Status" class="form-select form-select-sm">
                        <option value="Pending">Pending</option>
                        <option value="Issued">Issued / Ready for Print</option>
                    </select>
                </div>
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-sm btn-light border px-3">Discard</a>
                    <button type="submit" class="btn btn-sm btn-success px-4">Update Log</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>