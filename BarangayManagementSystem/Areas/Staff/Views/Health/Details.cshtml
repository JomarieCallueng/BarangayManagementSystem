@model BarangayCMS.Areas.Staff.ViewModels.HealthViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Health Profile Details</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="container py-5" style="max-width: 700px;">
        <div class="card border-0 shadow-sm p-4 rounded-3 mb-3">
            <div class="border-bottom pb-3 mb-3">
                <span class="badge bg-info bg-opacity-10 text-info mb-2 px-2 py-1"><i class="bi bi-heart-pulse-fill"></i> Confidential Health File</span>
                <h4 class="text-muted small fw-bold mb-1">PATIENT / RESIDENT FULL NAME</h4>
                <h3 class="fw-bold text-dark mb-0">@Model.ResidentFullName</h3>
            </div>

            <div class="row g-3 mb-4 small">
                <div class="col-md-6">
                    <span class="text-muted d-block fw-bold mb-1">DIAGNOSED MEDICAL CONDITION</span>
                    <div class="p-2 bg-info bg-opacity-10 text-info border border-info rounded fw-bold">@Model.MedicalCondition</div>
                </div>
                <div class="col-md-6">
                    <span class="text-muted d-block fw-bold mb-1">DATE AND TIME ENCODED</span>
                    <div class="p-2 bg-light border rounded text-secondary fw-semibold"><i class="bi bi-calendar3 me-1"></i> @Model.DateRecorded.ToString("F")</div>
                </div>
            </div>

            <div>
                <span class="text-muted small d-block fw-bold mb-1">CLINICAL REMARKS & ADVISORY NOTES</span>
                <p class="text-secondary p-3 border rounded bg-white font-monospace" style="white-space: pre-line; line-height: 1.6; min-height: 120px;">@Model.Remarks</p>
            </div>
        </div>
        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3"><i class="bi bi-arrow-left"></i> Patient Index</a>
            <a asp-action="Edit" asp-route-id="@Model.HealthRecordId" class="btn btn-sm btn-primary px-4"><i class="bi bi-pencil-square"></i> Edit Case Record</a>
        </div>
    </div>
</body>
</html>