@model BarangayCMS.Areas.Staff.ViewModels.HealthViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>New Medical Log</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container py-5" style="max-width: 650px;">
        <div class="card border-0 shadow-sm p-4 rounded-3">
            <h5 class="fw-bold text-dark mb-1">Clinical Assessment Form</h5>
            <p class="text-muted small mb-4">I-tala ang kondisyong medikal o check-up findings ng residente.</p>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="ResidentId" class="form-label small fw-bold text-secondary"></label>
                    <select asp-for="ResidentId" asp-items="Model.ResidentDataSource" class="form-select form-select-sm">
                        <option value="">-- Pumili ng Residente (Patient) --</option>
                    </select>
                    <span asp-validation-for="ResidentId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MedicalCondition" class="form-label small fw-bold text-secondary"></label>
                    <input asp-for="MedicalCondition" class="form-control form-control-sm" placeholder="e.g., Asthma, Hypertension, Dental Checkup" />
                    <span asp-validation-for="MedicalCondition" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DateRecorded" class="form-label small fw-bold text-secondary"></label>
                    <input asp-for="DateRecorded" class="form-control form-control-sm" type="datetime-local" />
                    <span asp-validation-for="DateRecorded" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Remarks" class="form-label small fw-bold text-secondary"></label>
                    <textarea asp-for="Remarks" class="form-control form-control-sm" rows="4" placeholder="Isulat ang ibinigay na gamot, payo ng doktor, o iba pang detalye ng konsultasyon..."></textarea>
                    <span asp-validation-for="Remarks" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-sm btn-light border px-3">Cancel</a>
                    <button type="submit" class="btn btn-sm btn-info text-white px-4 fw-bold">Save Health Entry</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>