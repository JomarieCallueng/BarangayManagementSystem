@model IEnumerable<BarangayCMS.Areas.Staff.ViewModels.HealthViewModel>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Areas/Staff/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Barangay Health Center Desk";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <small class="text-muted text-uppercase fw-bold">Medical</small>
        <h2 class="fw-bold text-dark m-0"><i class="bi bi-heart-pulse-fill text-primary me-2"></i>Health Center Records</h2>
        <p class="text-muted small mb-0">Monitor maternal health profiles, immunization records, and medical consultations.</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary fw-semibold px-4 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> New Consultation Log
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary small fw-bold">
                    <tr>
                        <th class="ps-4 py-3">Patient Name</th>
                        <th class="py-3">Classification</th>
                        <th class="py-3">Condition</th>
                        <th class="py-3">Vaccinated?</th>
                        <th class="py-3">Last Check-up</th>
                        <th class="text-end pe-4 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody class="small">
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                <i class="bi bi-activity display-6 d-block mb-2 text-secondary"></i>
                                Walang pasyente o konsultasyon na nakatala sa registry.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-dark">
                                    @item.ResidentName
                                    <small class="d-block text-muted" style="font-size: 0.75rem;">Blood Type: @(string.IsNullOrEmpty(item.BloodType) ? "N/A" : item.BloodType)</small>
                                </td>
                                <td>
                                    <span class="badge bg-blue-subtle text-primary px-2.5 py-1.5 rounded fw-medium">
                                        @item.HealthClassification
                                    </span>
                                </td>
                                <td class="text-secondary fw-medium">
                                    @if (item.MedicalCondition == "None" || string.IsNullOrEmpty(item.MedicalCondition))
                                    {
                                        <span class="text-muted">None</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger"><i class="bi bi-exclamation-circle me-1"></i>@item.MedicalCondition</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsVaccinated)
                                    {
                                        <span class="badge bg-success-subtle text-success px-2 py-1 rounded-pill"><i class="bi bi-check-lg"></i> Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-2 py-1 rounded-pill"><i class="bi bi-x"></i> No</span>
                                    }
                                </td>
                                <td class="text-secondary">@item.LastCheckupDate.ToString("MM/dd/yyyy")</td>
                                <td class="text-end pe-4">
                                    <a asp-action="ViewRecord" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary border-secondary-subtle">
                                        <i class="bi bi-folder2-open"></i> History
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-blue-subtle {
        background-color: #e7f1ff;
    }

    .bg-success-subtle {
        background-color: #e6f6ec;
    }

    .bg-danger-subtle {
        background-color: #ffeef2;
    }
</style>
