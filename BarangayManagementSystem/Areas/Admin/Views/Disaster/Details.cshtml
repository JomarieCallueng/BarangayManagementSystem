@model BarangayCMS.Web.Areas.Admin.Models.DisasterViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Detalye ng Kalamidad";
}

<div class="container mt-4" style="max-width: 650px;">
    <div class="card shadow">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0"><i class="bi bi-info-circle"></i> Sitwasyon ng Insidente</h4>
        </div>
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start border-bottom pb-2 mb-3">
                <div>
                    <h2 class="text-danger mb-0">@Model.DisasterType</h2>
                    <p class="text-muted mb-0"><i class="bi bi-geo-alt-fill"></i> @Model.Location</p>
                </div>
                <span class="badge bg-dark p-2 fs-6">@Model.Status</span>
            </div>

            <div class="mb-4">
                <label class="fw-bold text-muted small d-block">Kailan Nagdaos / Nangyari:</label>
                <p class="fs-5 text-dark">@Model.DateOccurred.ToString("MMMM dd, yyyy - hh:mm tt")</p>
            </div>

            <div>
                <label class="fw-bold text-muted small d-block">Ulat / Detalye ng Sitwasyon:</label>
                <div class="bg-light p-3 border rounded text-wrap style-plain fs-6" style="white-space: pre-wrap; min-height: 120px;">
                    @(string.IsNullOrEmpty(Model.Description) ? "Walang karagdagang deskripsyon na inilagay." : Model.Description)
                </div>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between bg-white">
            <a asp-action="Index" class="btn btn-secondary">Bumalik sa Monitor</a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil"></i> Baguhin ang Status</a>
        </div>
    </div>
</div>
