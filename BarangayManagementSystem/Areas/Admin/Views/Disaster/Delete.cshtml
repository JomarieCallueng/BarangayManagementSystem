@model BarangayCMS.Web.Areas.Admin.Models.DisasterViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Alisin ang Ulat";
}

<div class="container mt-4" style="max-width: 450px;">
    <div class="card border-danger shadow">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0"><i class="bi bi-trash-fill"></i> Burahin ang Record</h4>
        </div>
        <div class="card-body text-center">
            <h5 class="mb-3">Sigurado ka bang nais mong burahin ang ulat ng insidenteng ito?</h5>

            <div class="alert alert-danger text-start">
                <strong>Uri:</strong> @Model.DisasterType <br />
                <strong>Lugar:</strong> @Model.Location <br />
                <strong>Petsa:</strong> @Model.DateOccurred.ToString("yyyy-MM-dd")
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">I-cancel</a>
            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-4">Oo, Burahin</button>
            </form>
        </div>
    </div>
</div>
