@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Hazard Maps & Guidelines";
}

<div class="container mt-4" style="max-width: 800px;">
    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-map-fill"></i> Flood & Fire Hazard Zones</h4>
            <a asp-action="Index" class="btn btn-sm btn-outline-light">Bumalik</a>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <h5><i class="bi bi-info-triangle-fill"></i> Paalala sa mga High-Risk Zones</h5>
                Ang mga sumusunod na purok ay madalas bahain tuwing may malakas na bagyo:
                <ul class="mb-0 mt-2">
                    <li>Purok 4 (Tabing Ilog) - Critical Flood Level Area</li>
                    <li>Sitio Maligaya - High Risk para sa Landslide</li>
                </ul>
            </div>

            <div class="p-5 bg-light border text-center rounded text-muted mt-4">
                <i class="bi bi-file-earmark-image fs-1 d-block mb-2"></i>
                <span class="d-block fw-bold text-dark">Barangay Hazard Grid View</span>
                <small>Dito pwedeng ilagay o i-embed ang isang interactive image map o public emergency guidelines document.</small>
            </div>
        </div>
    </div>
</div>
