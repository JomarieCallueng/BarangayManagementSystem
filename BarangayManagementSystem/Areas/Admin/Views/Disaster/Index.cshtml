@model IEnumerable<BarangayCMS.Web.Areas.Admin.Models.DisasterViewModel>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Disaster Risk & Rescue Logs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark mb-1"><i class="bi bi-shield-exclamation text-danger me-2"></i>Disaster Risk & Emergency Logs</h2>
        <p class="text-muted small mb-0">Monitor incident profiles, location statuses, and disaster response within the barangay.</p>
    </div>
    <!-- 🔑 Ginawang ASP Tag Helper ang link para sa malinis na pag-route -->
    <a asp-area="Admin" asp-controller="Disaster" asp-action="Create" class="btn btn-danger shadow-sm fw-semibold">
        <i class="bi bi-plus-lg me-1"></i> Log Emergency Incident
    </a>
</div>

<div class="card border-0 shadow-sm rounded p-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Uri ng Kalamidad (Type)</th>
                    <th>Apektadong Lugar (Location)</th>
                    <th>Petsa at Oras (Date/Time)</th>
                    <th>Status ng Sitwasyon</th>
                    <th class="text-end">Aksyon (Actions)</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="fw-semibold text-dark d-block">@item.DisasterType</span>
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <small class="text-muted d-inline-block text-truncate" style="max-width: 250px;">@item.Description</small>
                                }
                            </td>
                            <td>
                                <i class="bi bi-geo-alt-fill text-danger me-1"></i> @(string.IsNullOrEmpty(item.Location) ? "Hindi Tukoy" : item.Location)
                            </td>
                            <td>
                                <i class="bi bi-calendar-event me-1 text-muted"></i> @item.DateOccurred.ToString("MM/dd/yyyy hh:mm tt")
                            </td>
                            <td>
                                <!-- Dynamic Badge para sa Status base sa iyong model options -->
                                @if (item.Status == "Active")
                                {
                                    <span class="badge bg-danger">Active</span>
                                }
                                else if (item.Status == "Controlled")
                                {
                                    <span class="badge bg-warning text-dark">Controlled</span>
                                }
                                else if (item.Status == "Resolved")
                                {
                                    <span class="badge bg-success">Resolved</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Status</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group" role="group">
                                    <a asp-area="Admin" asp-controller="Disaster" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning me-1" title="Baguhin">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-area="Admin" asp-controller="Disaster" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Burahin">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="bi bi-shield-slash display-6 d-block mb-2 text-secondary"></i>
                            <span>Walang aktibong ulat ng kalamidad o insidente sa kasalukuyan. Ligtas ang buong barangay.</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>