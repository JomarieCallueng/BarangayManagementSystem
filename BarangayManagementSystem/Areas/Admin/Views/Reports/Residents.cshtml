@model IEnumerable<BarangayCMS.Web.Areas.Admin.Models.ResidentReportItem>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Demographic Report";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-people-fill"></i> Ulat ng Demograpiko ng mga Resident</h4>
        <!-- 🔑 NAAYOS: Nilagyan ng Admin routing path at Tag Helper guard -->
        <a asp-area="Admin" asp-controller="Reports" asp-action="Index" class="btn btn-sm btn-outline-secondary">Bumalik</a>
    </div>

    <div class="card shadow-sm">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Buong Pangalan</th>
                    <th>Edad</th>
                    <th>Kasarian</th>
                    <th>Purok</th>
                    <th>Voter Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Name</strong></td>
                        <td>@item.Age</td>
                        <td>@item.Gender</td>
                        <td>@item.Purok</td>
                        <td><span class="badge bg-secondary">@item.Status</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>