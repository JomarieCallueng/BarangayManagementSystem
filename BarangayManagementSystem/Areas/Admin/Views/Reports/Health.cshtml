@model IEnumerable<BarangayCMS.Web.Areas.Admin.Models.HealthReportItem>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Barangay Health & Nutrition Report";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-heart-pulse-fill text-danger"></i> Ulat ng Kalusugan sa Komunidad</h4>
        <!-- 🔑 NAAYOS: Idinagdag ang asp-area at asp-controller para sigurado ang balik sa Reports main engine -->
        <a asp-area="Admin" asp-controller="Reports" asp-action="Index" class="btn btn-sm btn-outline-secondary">Bumalik</a>
    </div>

    <div class="card shadow-sm">
        <table class="table table-striped mb-0">
            <thead class="table-success">
                <tr>
                    <th>Pangalan ng Residente</th>
                    <th>Kategorya / Kondisyon</th>
                    <th>Tulong/Gamot na Natanggap</th>
                    <th>Petsa ng Pagsusuri</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in Model)
                {
                    <tr>
                        <td><strong>@h.ResidentName</strong></td>
                        <td><span class="badge bg-info text-dark">@h.Condition</span></td>
                        <td>@h.AssistanceReceived</td>
                        <td>@h.DateChecked.ToShortDateString()</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>