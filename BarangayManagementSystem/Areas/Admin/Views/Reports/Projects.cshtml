@model IEnumerable<BarangayCMS.Web.Areas.Admin.Models.ProjectReportItem>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Infrastructure & Development Projects";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-hammer text-warning"></i> Monitoring ng mga Proyekto ng Barangay</h4>
        <a asp-area="Admin" asp-controller="Reports" asp-action="Index" class="btn btn-sm btn-outline-secondary">Bumalik</a>
    </div>

    <div class="row">
        @foreach (var project in Model)
        {
            var remaining = project.BudgetAllocated - project.TotalExpenses;
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm h-100 border-start border-warning border-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="fw-bold mb-1">@project.Title</h5>
                            <span class="badge bg-info text-dark">@project.Status</span>
                        </div>
                        <p class="text-muted small mb-2"><i class="bi bi-geo-alt me-1"></i>Lokasyon: @project.Location</p>
                        <p class="text-muted small mb-2"><i class="bi bi-person-badge me-1"></i>Kontratista: @project.Contractor</p>

                        <hr class="my-2" />

                        <div class="d-flex justify-content-between small text-secondary">
                            <span>Inilaang Badyet: <strong>₱@project.BudgetAllocated.ToString("N2")</strong></span>
                            <span>Nagastos: <strong class="text-danger">₱@project.TotalExpenses.ToString("N2")</strong></span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>