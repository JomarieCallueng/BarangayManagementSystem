@model IEnumerable<BarangayCMS.Web.Areas.Admin.Models.ComplaintReportItem>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Blotter Report";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-shield-exclamation text-danger"></i> Ulat ng mga Reklamo at Blotter</h4>
        <!-- 🔑 NAAYOS: Idinagdag ang tag helpers at eksaktong ruta para makabalik nang maayos -->
        <a asp-area="Admin" asp-controller="Reports" asp-action="Index" class="btn btn-sm btn-outline-secondary">Bumalik</a>
    </div>

    <div class="card shadow-sm">
        <table class="table table-striped mb-0">
            <thead class="table-danger">
                <tr>
                    <th>Case ID</th>
                    <th>Nagreklamo</th>
                    <th>Ipinagsakdal</th>
                    <th>Uri ng Kaso</th>
                    <th>Petsa</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.CaseId</td>
                        <td>@item.Complainant</td>
                        <td>@item.Respondent</td>
                        <td>@item.CaseType</td>
                        <td>@item.DateFiled.ToString("yyyy-MM-dd")</td>
                        <td><span class="badge @(item.Status == "Resolved" ? "bg-success" : "bg-warning text-dark")">@item.Status</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>