@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model BarangayCMS.Web.Areas.Admin.Models.ReportsDashboardViewModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Export Data and Printing Options";
}

<div class="container mt-4 mb-5" style="max-width: 650px;">
    <div class="card shadow-lg text-center border-0 py-4 card-export-body">
        <div class="card-body">
            <div class="mb-3">
                <i class="bi bi-printer-fill text-secondary display-3"></i>
            </div>
            <h4 class="fw-bold text-dark">Sentro ng Pag-export ng Opisyal na Ulat</h4>
            <p class="text-muted small px-3">Pumili ng kaukulang format sa ibaba upang i-save o i-print ang buong pinagsama-samang data para sa ebalwasyon ng pamahalaang lokal.</p>
            <hr />

            <div class="d-grid gap-3 px-4">
                <!-- 🖨️ OPSIYON 1: Print / Save as PDF gamit ang Browser Print -->
                <button onclick="window.print();" class="btn btn-danger btn-lg fw-bold shadow-sm mb-2">
                    <i class="bi bi-file-earmark-pdf-fill me-2"></i> I-download bilang PDF (Print View)
                </button>

                <!-- 📊 OPSIYON 2: Excel Export Link -->
                <a asp-area="Admin" asp-controller="Reports" asp-action="ExportExcel" class="btn btn-success btn-lg fw-bold shadow-sm mb-2">
                    <i class="bi bi-file-earmark-excel-fill me-2"></i> I-export sa Microsoft Excel (.xlsx)
                </a>

                <hr />

                <!-- 🔙 NAVIGATION BUTTONS (Siguraduhing clickable at hindi sakop ng print hide screens) -->
                <div class="d-flex justify-content-between gap-2 isolation-layer">
                    <a asp-area="Admin" asp-controller="Reports" asp-action="Index" class="btn btn-outline-secondary w-50 py-2">
                        <i class="bi bi-arrow-left-short"></i> Balik sa Ulat
                    </a>
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary w-50 py-2">
                        <i class="bi bi-house-door"></i> Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 🔑 PINAGALING AT NAAYOS NA CSS PRINT GUARD -->
<style>
    @@media print {
        /* Itatago LAMANG ang mga buttons kapag aktwal nang nag-pi-print ang printer/PDF save dialog */
        .sidebar, .nav, .navbar, .btn, hr, .text-muted, header, footer,
        #sidebarMenu, .sidebar-wrapper, .isolation-layer {
            display: none !important;
        }
        /* Isasagad ang card sa buong papel ng PDF nang walang margin gaps */
        .container {
            width: 100% !important;
            max-width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        .card-export-body {
            border: none !important;
            box-shadow: none !important;
            background: transparent !important;
        }
    }
</style>