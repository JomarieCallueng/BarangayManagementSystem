@model IEnumerable<BarangayCMS.Web.Areas.Admin.Models.BudgetReportItem>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Financial Budget Report";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-cash-coin text-success"></i> Ulat sa Pananalapi at Pondo ng Barangay</h4>
        <a asp-area="Admin" asp-controller="Reports" asp-action="Index" class="btn btn-sm btn-outline-secondary">Bumalik</a>
    </div>

    <div class="card shadow-sm">
        <table class="table table-bordered mb-0">
            <thead class="table-success">
                <tr>
                    <th>Taon</th>
                    <th>Kategorya / Pondo</th>
                    <th>Paglalarawan</th>
                    <th>Inilaang Pondo</th>
                    <th>Nagastos na Halaga</th>
                    <th>Natitirang Badyet</th>
                    <th>Inirehistro Ni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Year</strong></td>
                        <td><span class="badge bg-light text-dark border">@item.Category</span></td>
                        <td>@item.Description</td>
                        <td>₱@item.TotalAllocation.ToString("N2")</td>
                        <td class="text-danger">₱@item.DisbursedAmount.ToString("N2")</td>
                        <td class="fw-bold text-success">₱@item.RemainingBalance.ToString("N2")</td>
                        <td class="small text-muted">@item.LoggedBy</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>