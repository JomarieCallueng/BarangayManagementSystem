@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Waste Collection Schedule";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-truck text-primary"></i> Iskedyul ng Paghahakot ng Basura</h2>
        <a asp-action="Index" class="btn btn-secondary btn-sm">Bumalik</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white fw-bold">
            Iskedyul Kada Sektor / Purok
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Araw</th>
                        <th>Uri ng Basura</th>
                        <th>Mga Sakop na Purok / Lugar</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Lunes at Huwebes</strong></td>
                        <td><span class="badge bg-warning text-dark">Nabubulok (Biodegradable)</span></td>
                        <td>Purok 1, Purok 2, Purok 3</td>
                    </tr>
                    <tr>
                        <td><strong>Martes at Biyernes</strong></td>
                        <td><span class="badge bg-secondary">Di-Nabubulok (Non-Biodegradable)</span></td>
                        <td>Purok 4, Purok 5, Sitio Central</td>
                    </tr>
                    <tr>
                        <td><strong>Rekomendasyon</strong></td>
                        <td><span class="badge bg-danger">Recyclable / Hazardous</span></td>
                        <td>Tuwing huling Linggo ng Buwan (Barangay Eco-Hub)</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>