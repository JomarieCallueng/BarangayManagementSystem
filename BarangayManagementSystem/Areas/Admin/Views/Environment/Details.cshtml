@model BarangayCMS.Web.Areas.Admin.Models.EnvironmentViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Detalye ng Aktibidad";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0"><i class="bi bi-info-circle"></i> Impormasyon ng Programa</h4>
        </div>
        <div class="card-body">
            <h3 class="text-success border-bottom pb-2">@Model.ActivityName</h3>

            <div class="mb-3 mt-3">
                <label class="fw-bold text-muted small d-block">Lugar / Lokasyon:</label>
                <p class="fs-5">@Model.Location</p>
            </div>

            <div class="mb-3">
                <label class="fw-bold text-muted small d-block">Petsa at Oras:</label>
                <p class="fs-6 text-dark fw-bold">@Model.ActivityDate.ToString("MMMM dd, yyyy - hh:mm tt")</p>
            </div>

            <div class="mb-2">
                <label class="fw-bold text-muted small d-block">Deskripsyon / Layunin:</label>
                <div class="bg-light p-3 border rounded text-wrap fs-6" style="white-space: pre-wrap; min-height: 100px;">
                    @(string.IsNullOrEmpty(Model.Description) ? "Walang nakasulat na deskripsyon." : Model.Description)
                </div>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between bg-white">
            <a asp-action="Index" class="btn btn-secondary">Bumalik</a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">I-edit</a>
        </div>
    </div>
</div>