@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Community Cleanup Drives";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-people-fill text-success"></i> Community Cleanup Drive Schedule</h2>
        <a asp-action="Index" class="btn btn-secondary btn-sm">Bumalik</a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 g-4">
        <div class="col">
            <div class="card h-100 border-start border-success border-4 shadow-sm">
                <div class="card-body">
                    <span class="badge bg-success mb-2">Weekly Routine</span>
                    <h5 class="card-title fw-bold">Tapat Mo, Linis Mo Drive</h5>
                    <p class="text-muted">Isinasagawa tuwing Sabado ng umaga sa lahat ng Purok (6:00 AM - 8:00 AM).</p>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 border-start border-primary border-4 shadow-sm">
                <div class="card-body">
                    <span class="badge bg-primary mb-2">Monthly Project</span>
                    <h5 class="card-title fw-bold">Oplan Linis Estero / Ilog</h5>
                    <p class="text-muted">Pangkalahatang paglilinis ng mga daluyan ng tubig upang maiwasan ang pagbaha.</p>
                </div>
            </div>
        </div>
    </div>
</div>