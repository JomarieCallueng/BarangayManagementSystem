@model IEnumerable<BarangayCMS.Web.Areas.Admin.Models.EnvironmentViewModel>

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Environment & Sanitation";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark mb-1"><i class="bi bi-tree text-success me-2"></i>Environment & Sanitation</h2>
        <p class="text-muted small mb-0">Manage waste collection cycles, community cleanups, and greening program monitors.</p>
    </div>
    <a href="/Admin/Environment/Create" class="btn btn-success shadow-sm fw-semibold">
        <i class="bi bi-plus-lg me-1"></i> Add Clean-up Activity
    </a>
</div>

<div class="card border-0 shadow-sm rounded p-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Activity Name & Description</th>
                    <th>Location / Area</th>
                    <th>Activity Date</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold text-dark">
                                @item.ActivityName <br />
                                <small class="text-muted fw-normal">@item.Description</small>
                            </td>
                            <td>
                                <i class="bi bi-geo-alt text-danger me-1"></i> @(string.IsNullOrEmpty(item.Location) ? "Not Specified" : item.Location)
                            </td>
                            <td>
                                <i class="bi bi-calendar-event me-1"></i> @item.ActivityDate.ToString("MM/dd/yyyy")
                            </td>
                            <td class="text-end">
                                <a href="/Admin/Environment/Edit/@item.Id" class="btn btn-sm btn-outline-primary me-1" title="Edit"><i class="bi bi-pencil"></i></a>
                                <a href="/Admin/Environment/Delete/@item.Id" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="bi bi-tree-fill display-6 d-block mb-2 text-success opacity-50"></i>
                            <span>No scheduled environmental sanitation programs found.</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>