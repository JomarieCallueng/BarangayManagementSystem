@model IEnumerable<BarangayCMS.Web.Areas.Admin.Models.HealthViewModel>


@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Immunization Log";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-shield-plus text-info"></i> Talaan ng mga Binakunahan (Immunization Log)</h2>
        <a asp-action="Index" class="btn btn-secondary btn-sm">Bumalik sa Center</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead class="table-info">
                    <tr>
                        <th>Pasyente</th>
                        <th>Bakuna / Tipo ng Immunization</th>
                        <th>Petsa ng Turok</th>
                        <th>Remarks / Batch</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.ResidentName</strong></td>
                                <td><span class="badge bg-success">@item.MedicalCondition</span></td>
                                <td>@item.DateRecorded.ToString("yyyy-MM-dd")</td>
                                <td class="text-muted small">@item.Remarks</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">Walang nakitang rekord ng immunization/bakuna sa database.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>