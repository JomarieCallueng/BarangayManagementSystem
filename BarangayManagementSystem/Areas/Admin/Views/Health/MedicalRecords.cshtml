@model IEnumerable<BarangayCMS.Web.Areas.Admin.Models.HealthViewModel>


@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Clinical Records";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-journal-medical text-dark"></i> Pangkalahatang Clinical / Check-up History</h2>
        <a asp-action="Index" class="btn btn-secondary btn-sm">Bumalik sa Center</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-bordered table-hover mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Residente</th>
                        <th>Diagnosis / Sakit</th>
                        <th>Petsa ng Konsultasyon</th>
                        <th>Medikasyon / Rekomendasyon</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.ResidentName</strong></td>
                                <td class="text-danger fw-bold">@item.MedicalCondition</td>
                                <td>@item.DateRecorded.ToString("MMMM dd, yyyy")</td>
                                <td class="text-wrap">@item.Remarks</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">Walang nakatalang clinical history maliban sa bakuna.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>