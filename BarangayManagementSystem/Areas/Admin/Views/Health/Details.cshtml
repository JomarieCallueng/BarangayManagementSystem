@model BarangayCMS.Web.Areas.Admin.Models.HealthViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Medikal na Detalye";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0"><i class="bi bi-file-earmark-medical"></i> Detalye ng Kasaysayang Medikal</h4>
        </div>
        <div class="card-body">
            <div class="border-bottom pb-2 mb-3">
                <label class="fw-bold text-muted small d-block">Pangalan ng Pasyente / Residente:</label>
                <h3 class="text-primary mb-0">@Model.ResidentName</h3>
            </div>

            <div class="mb-3">
                <label class="fw-bold text-muted small d-block">Diagnosis / Medikal na Kondisyon:</label>
                <p class="fs-5 text-danger fw-bold">@Model.MedicalCondition</p>
            </div>

            <div class="mb-3">
                <label class="fw-bold text-muted small d-block">Petsa ng Pagkakatala:</label>
                <p class="fs-6 text-dark">@Model.DateRecorded.ToString("MMMM dd, yyyy")</p>
            </div>

            <div class="mb-2">
                <label class="fw-bold text-muted small d-block">Remarks / Doktor Prescriptions:</label>
                <div class="bg-light p-3 border rounded fs-6" style="white-space: pre-wrap; min-height: 100px;">
                    @(string.IsNullOrEmpty(Model.Remarks) ? "Walang naitalang karagdagang detalye o reseta." : Model.Remarks)
                </div>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between bg-white">
            <a asp-action="Index" class="btn btn-secondary">Bumalik sa Listahan</a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">I-edit ang Log</a>
        </div>
    </div>
</div>