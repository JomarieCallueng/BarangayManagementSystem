@model IEnumerable<BarangayCMS.Web.Areas.Admin.Models.CertificateViewModel>

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Certificates Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark mb-1"><i class="bi bi-file-earmark-text text-primary me-2"></i>Certificates Management</h2>
        <p class="text-muted small mb-0">Manage barangay clearances, indigency certificates, and permit issuances.</p>
    </div>

    <!-- 🌟 MGA BUTTONS (Pinagsama sa d-flex gap-2 para laging magkatabi nang maayos) -->
    <div class="d-flex gap-2">
        <a href="/Admin/AdminCertificateTypes" class="btn btn-outline-primary shadow-sm fw-semibold">
            <i class="bi bi-gear-fill me-1"></i> Setup Prices
        </a>
        <a href="/Admin/Certificates/Create" class="btn btn-primary shadow-sm fw-semibold">
            <i class="bi bi-plus-lg me-1"></i> Issue New Certificate
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm rounded p-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Document Type</th>
                    <th>Resident Name</th>
                    <th>Date Requested</th>
                    <th>Fee & Receipt</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold text-dark">@item.CertificateType</td>
                            <td>@item.ResidentFullName</td>
                            <td>@item.DateRequested.ToString("MM/dd/yyyy")</td>

                            <!-- FEE & PROOF OF PAYMENT COLUMN -->
                            <td>
                                @if (item.FeePaid > 0)
                                {
                                    <div class="d-flex flex-column align-items-start gap-1">
                                        <span class="badge bg-success-subtle text-success fw-bold">
                                            ₱@item.FeePaid.ToString("N2")
                                        </span>
                                        @if (!string.IsNullOrEmpty(item.PaymentReceiptPath))
                                        {
                                            <a href="@item.PaymentReceiptPath" target="_blank" class="small text-primary text-decoration-underline" style="font-size: 12px;">
                                                <i class="bi bi-file-earmark-image me-1"></i>View Receipt
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted" style="font-size: 11px; font-style: italic;">No Receipt</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted">FREE</span>
                                }
                            </td>

                            <td>
                                @if (item.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                                else if (item.Status == "Issued")
                                {
                                    <span class="badge bg-success">Issued</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Status</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (item.Status == "Pending")
                                {
                                    <a href="/Admin/Certificates/Generate/@item.Id" class="btn btn-sm btn-outline-success me-1 fw-semibold">Approve / Generate</a>
                                }
                                <a href="/Admin/Certificates/Details/@item.Id" class="btn btn-sm btn-outline-info text-info me-1" title="View"><i class="bi bi-info-circle"></i></a>
                                <a href="/Admin/Certificates/Delete/@item.Id" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="bi bi-file-earmark display-6 d-block mb-2"></i>
                            <span>No certificate requests found.</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>