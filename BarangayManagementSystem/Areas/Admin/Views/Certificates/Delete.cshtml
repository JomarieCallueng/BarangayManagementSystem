@model BarangayCMS.Web.Areas.Admin.Models.CertificateViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Delete Request Log";
}

<div class="container mt-4" style="max-width: 550px;">
    <div class="card border-danger shadow">
        <div class="card-header bg-danger text-white py-3">
            <h4 class="mb-0 fw-bold"><i class="bi bi-trash-fill me-2"></i>Delete Request Log</h4>
        </div>
        <div class="card-body p-4">
            <h5 class="text-center text-dark mb-4 fw-semibold">Are you sure you want to delete this certificate request entry?</h5>

            <div class="p-3 rounded mb-4" style="background-color: #f8d7da; border: 1px solid #f5c6cb;">
                <p class="mb-1 text-danger"><strong>Resident:</strong> @Model.ResidentFullName</p>
                <p class="mb-1 text-danger"><strong>Type:</strong> @Model.CertificateType</p>
                <p class="mb-0 text-danger"><strong>Status:</strong> @Model.Status</p>
            </div>

            <!-- 🔑 POST FORM WITH ANTI-FORGERY TOKEN FOR ERROR 400 PREVENTION -->
            <form asp-area="Admin" asp-controller="Certificates" asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-center gap-3">
                    <a asp-area="Admin" asp-controller="Certificates" asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-danger px-4 fw-bold">Confirm Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>