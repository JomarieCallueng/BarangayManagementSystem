@model BarangayCMS.Web.Areas.Admin.Models.CertificateViewModel

@{
    ViewData["Title"] = "Certificate Request Details";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

<div class="container-fluid px-4 py-5">
    <div class="mb-4">
        <h2 class="fw-bold text-dark mb-1">
            <i class="bi bi-file-earmark-text text-primary me-2"></i> Request Details & Verification
        </h2>
        <p class="text-muted mb-0">Review the details, verify the proof of payment, and adjust the price if needed.</p>
    </div>

    <div class="row g-4">
        <!-- KALIWANG COLUMN: REQUEST DETAILS & EDITABLE PRICE -->
        <div class="col-lg-6">
            <form asp-area="Admin" asp-controller="Certificates" asp-action="Generate" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ResidentId" />

                <div class="card border-0 shadow-sm rounded-3 mb-4">
                    <div class="card-body p-4 bg-white">
                        <h5 class="fw-bold text-secondary mb-4 border-bottom pb-2">Information Summary</h5>

                        <div class="mb-3">
                            <span class="text-muted d-block small fw-semibold">Resident Beneficiary</span>
                            <span class="fs-5 fw-bold text-dark">@Model.ResidentFullName</span>
                        </div>

                        <div class="mb-3">
                            <span class="text-muted d-block small fw-semibold">Document Form Type</span>
                            <span class="fs-5 fw-bold text-primary">@Model.CertificateType</span>
                        </div>

                        <div class="mb-3">
                            <span class="text-muted d-block small fw-semibold">Date Requested</span>
                            <span class="fs-6 fw-semibold text-dark">@Model.DateRequested.ToString("MMMM dd, yyyy")</span>
                        </div>

                        <div class="mb-3">
                            <span class="text-muted d-block small fw-semibold">Current Status</span>
                            <span class="badge bg-warning text-dark px-3 py-2 fs-6 mt-1">@Model.Status</span>
                        </div>

                        <hr class="my-4" />

                        <!-- EDITABLE PRICE FIELD -->
                        <div class="mb-3">
                            <label class="form-label fw-bold text-success">
                                <i class="bi bi-cash-coin me-1"></i> Final Amount / Fee (₱)
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-success text-white fw-bold">₱</span>
                                <input type="number"
                                       step="0.01"
                                       min="0"
                                       class="form-control form-control-lg border-success fw-bold text-success"
                                       id="FeePaid"
                                       name="FeePaid"
                                       value="@Model.FeePaid.ToString("0.00")"
                                       placeholder="0.00" />
                            </div>
                            <small class="text-muted">Maaari mong palitan ang halaga rito base sa beripikasyon sa resibo.</small>
                            <span asp-validation-for="FeePaid" class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <!-- ACTION BUTTONS -->
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-4 bg-light">
                        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-between">

                            <!-- DIRECT BACK URL -->
                            <a href="/Admin/Certificates" class="btn btn-outline-secondary px-4 py-2 fw-semibold">
                                <i class="bi bi-arrow-left me-1"></i> Back
                            </a>

                            <div class="d-flex gap-2">
                                <button type="submit" name="Status" value="Rejected" class="btn btn-danger px-4 py-2 fw-bold shadow-sm">
                                    <i class="bi bi-x-circle me-1"></i> Reject
                                </button>

                                <button type="submit" name="Status" value="Issued" class="btn btn-success px-4 py-2 fw-bold shadow-sm">
                                    <i class="bi bi-check-circle me-1"></i> Approve & Issue
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <!-- KANANG COLUMN: PROOF OF PAYMENT PREVIEW -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-3 h-100">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="m-0 fw-bold text-dark">
                        <i class="bi bi-image text-primary me-2"></i>Proof of Payment
                    </h5>
                </div>
                <div class="card-body p-4 d-flex flex-column align-items-center justify-content-center bg-light rounded-bottom-3">
                    @if (!string.IsNullOrEmpty(Model.PaymentReceiptPath))
                    {
                        <div class="text-center w-100">
                            <p class="text-muted small mb-3">I-click ang larawan upang buksan ito sa malaking view.</p>

                            <a href="@Model.PaymentReceiptPath" target="_blank" title="Click to view full image">
                                <img src="@Model.PaymentReceiptPath" class="img-fluid rounded shadow-sm border" style="max-height: 400px; object-fit: contain; cursor: pointer; transition: 0.3s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'" />
                            </a>

                            <div class="mt-3">
                                <a href="@Model.PaymentReceiptPath" target="_blank" class="btn btn-outline-primary btn-sm fw-semibold">
                                    <i class="bi bi-box-arrow-up-right me-1"></i> Open Full Image
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-receipt-cutoff text-muted display-1 d-block mb-3"></i>
                            <span class="text-muted fw-semibold">Walang inupload na Proof of Payment ang residente.</span>
                            <p class="text-muted small px-3 mt-1">Maaaring ito ay walk-in o libreng transaksyon gaya ng Indigency.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>