@model IEnumerable<BarangayCMS.Web.Areas.Admin.Models.CertificateTemplateViewModel>
<div class="container mt-4">
    <h4><i class="bi bi-file-earmark-richtext"></i> Certificate & Clearance Templates</h4>
    <div class="row mt-3">
        @foreach (var t in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card h-100 border-info">
                    <div class="card-body">
                        <h5 class="card-title">@t.TemplateName</h5>
                        <p class="text-muted mb-1">Fee: ₱@t.Fee.ToString("N2")</p>
                        <p class="small">Digital Signature: @(t.IsDigitalSignEnabled ? "Enabled" : "Disabled")</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
