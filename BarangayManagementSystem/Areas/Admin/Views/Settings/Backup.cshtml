<div class="container mt-4 text-center" style="max-width: 500px;">
    <div class="card py-4 shadow border-warning">
        <div class="card-body">
            <i class="bi bi-cloud-upload display-1 text-warning"></i>
            <h3 class="mt-3">Database Maintenance</h3>
            <p class="text-muted">Backup your data regularly to prevent data loss during system failures.</p>
            <hr />
            <div class="d-grid gap-2">
                <button class="btn btn-warning btn-lg"><i class="bi bi-download"></i> Download Full Backup (.bak)</button>
                <button class="btn btn-outline-danger"><i class="bi bi-arrow-counterclockwise"></i> Restore from File</button>
            </div>
        </div>
    </div>
</div>