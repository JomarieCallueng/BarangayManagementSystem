@model IEnumerable<BarangayCMS.Web.Areas.Admin.Models.AuditLogViewModel>
<div class="container mt-4">
    <h4><i class="bi bi-clock-history"></i> System Activity Audit Logs</h4>
    <div class="card mt-3 shadow-sm">
        <table class="table table-hover mb-0">
            <thead class="table-secondary"><tr><th>Date/Time</th><th>User</th><th>Action Taken</th><th>Module</th></tr></thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr><td>@log.LogDate</td><td><strong>@log.User</strong></td><td>@log.Action</td><td><span class="badge bg-light text-dark border">@log.Module</span></td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
