@model IEnumerable<BarangayCMS.Web.Areas.Admin.Models.OfficialViewModel>
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-people-fill"></i> Current Barangay Officials</h4>
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Back to Hub</a>
    </div>
    <table class="table table-striped border shadow-sm">
        <thead class="table-dark"><tr><th>Name</th><th>Position</th><th>Status</th></tr></thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr><td>@item.Name</td><td>@item.Position</td><td><span class="badge bg-success">Active</span></td></tr>
            }
        </tbody>
    </table>
</div>
