@model BarangayCMS.Web.Areas.Admin.Models.UserViewModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Mga Detalye ng Account";
}

<div class="container mt-4" style="max-width: 500px;">
    <div class="card shadow">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0"><i class="bi bi-info-circle"></i> Detalye ng Account</h4>
        </div>
        <div class="card-body">
            <table class="table table-borderless">
                <tr>
                    <td class="fw-bold">Buong Pangalan:</td>
                    <td>@Model.FullName</td>
                </tr>
                <tr>
                    <td class="fw-bold">Username:</td>
                    <td><code>@Model.Username</code></td>
                </tr>
                <tr>
                    <td class="fw-bold">Email:</td>
                    <td>@Model.Email</td>
                </tr>
                <tr>
                    <td class="fw-bold">Tungkulin (Role):</td>
                    <td><span class="badge bg-secondary">@Model.Role</span></td>
                </tr>
            </table>
            <hr />
            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary">Bumalik</a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning text-white">I-edit</a>
            </div>
        </div>
    </div>
</div>
