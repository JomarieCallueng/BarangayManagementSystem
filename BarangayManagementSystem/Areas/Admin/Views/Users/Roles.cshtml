@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "System Roles";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-shield-lock"></i> Mga Tungkulin (Identity Roles)</h4>
        <a asp-action="Index" class="btn btn-outline-dark btn-sm">Bumalik sa Users</a>
    </div>

    <div class="card shadow-sm">
        <ul class="list-group list-group-flush">
            @if (Model != null)
            {
                foreach (var role in Model)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <strong>@role.Name</strong>
                        <span class="badge bg-dark rounded-pill">ID: @role.Id.Substring(0, 8)...</span>
                    </li>
                }
            }
        </ul>
    </div>
</div>