@model IEnumerable<BarangayCMS.Web.Areas.Admin.Models.UserViewModel>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "System User Accounts";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark mb-1">
            <i class="bi bi-person-gear text-primary me-2"></i>User Accounts
        </h2>
        <p class="text-muted small mb-0">Manage system login credentials, portal access levels, and account roles.</p>
    </div>

    <a asp-area="Admin" asp-controller="Users" asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-person-plus-fill me-1"></i> Create User Account
    </a>
</div>

<div class="card border-0 shadow-sm rounded p-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Username</th>
                    <th>Email Address</th>
                    <th>Full Name</th>
                    <th>Role Group</th>
                    <th class="text-center" style="width: 170px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="fw-semibold text-dark">@user.Username</td>
                            <td>@user.Email</td>
                            <td>@user.FullName</td>
                            <td>
                                <span class="badge @(user.Role == "SuperAdmin" ? "bg-dark" : "bg-primary")">
                                    @user.Role
                                </span>
                            </td>
                            <!-- 🔑 ACTION BUTTONS -->
                            <td class="text-center">
                                <div class="btn-group btn-group-sm" role="group">
                                    <!-- Edit / Reset Password -->
                                    <a asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@user.Id"
                                       class="btn btn-outline-warning text-dark" title="Edit Profile & Password">
                                        <i class="bi bi-pencil-square me-1"></i> Edit
                                    </a>

                                    <!-- Delete Button -->
                                    <form asp-area="Admin" asp-controller="Users" asp-action="Delete" asp-route-id="@user.Id"
                                          method="post" style="display:inline;"
                                          onsubmit="return confirm('Sigurado ka bang gusto mong burahin ang account ni @user.Username?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger" title="Delete User">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            No user accounts found in database.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>