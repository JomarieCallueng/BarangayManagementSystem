@model IEnumerable<BarangayCMS.Web.Areas.Admin.Models.ResidentViewModel>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Residents Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark mb-1">
            <i class="bi bi-people-fill text-primary me-2"></i>Residents Management
        </h2>
        <p class="text-muted small mb-0">Census data bank containing profiles, voting registrations, and households roster information.</p>
    </div>
    <a asp-area="Admin" asp-controller="Residents" asp-action="Create" class="btn btn-primary px-3 shadow-sm fw-semibold">
        <i class="bi bi-person-plus-fill me-1"></i> + Register Resident
    </a>
</div>

<div class="card border-0 shadow-sm rounded-3 mb-4 p-3 bg-white">
    <div class="row g-3">
        <div class="col-md-5">
            <div class="input-group">
                <label class="input-group-text bg-light border-end-0 text-muted fw-bold" for="purokFilterSelect">
                    <i class="bi bi-geo-alt-fill text-danger me-1"></i> Pumili ng Purok:
                </label>
                <select id="purokFilterSelect" class="form-select bg-light border-start-0 fw-semibold" onchange="filterResidents()">
                    <option value="">-- Lahat ng Purok (All Residents) --</option>
                </select>
            </div>
        </div>

        <div class="col-md-7">
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0 text-muted">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" id="residentSearchInput" class="form-control bg-light border-start-0" placeholder="Maghanap ng pangalan sa napiling purok..." onkeyup="filterResidents()">
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3 bg-white p-3">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="residentsTable">
            <thead class="table-light">
                <tr>
                    <th>Resident Name</th>
                    <th>Gender / Age</th>
                    <th>Purok Address</th>
                    <th>Voter Status</th> <!-- 👈 IDINAGDAG ANG VOTER COLUMN -->
                    <th>Contact Number</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr class="resident-row">
                            <td class="fw-bold text-dark resident-name">
                                @item.LastName, @item.FirstName @item.MiddleName
                            </td>
                            <td>
                                <span class="badge bg-secondary text-light">@item.Gender</span>
                                <small class="text-muted ms-1">(@item.Age yrs old)</small>
                            </td>
                            <td class="resident-purok fw-semibold text-primary">
                                @(string.IsNullOrEmpty(item.Purok) ? "N/A" : item.Purok)
                            </td>

                            <!-- 🗳️ VOTER BADGE DISPLAY -->
                            <td>
                                @if (item.IsVoter)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle-fill me-1"></i>Voter</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark border"><i class="bi bi-x-circle me-1"></i>Non-Voter</span>
                                }
                            </td>

                            <td>
                                @(string.IsNullOrEmpty(item.ContactNumber) ? "N/A" : item.ContactNumber)
                            </td>
                            <td class="text-center">
                                <a asp-area="Admin" asp-controller="Residents" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-area="Admin" asp-controller="Residents" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1" title="View Info">
                                    <i class="bi bi-info-circle"></i>
                                </a>
                                <a asp-area="Admin" asp-controller="Residents" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            Walang resident record na nahanap.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        populatePurokDropdown();
    });

    function populatePurokDropdown() {
        const purokSelect = document.getElementById('purokFilterSelect');
        const purokCells = document.querySelectorAll('.resident-purok');
        const uniquePuroks = new Set();

        purokCells.forEach(cell => {
            const purokText = cell.textContent.trim();
            if (purokText && purokText !== "N/A") {
                uniquePuroks.add(purokText);
            }
        });

        uniquePuroks.forEach(purok => {
            const option = document.createElement('option');
            option.value = purok;
            option.textContent = purok;
            purokSelect.appendChild(option);
        });
    }

    function filterResidents() {
        const selectedPurok = document.getElementById('purokFilterSelect').value.toLowerCase().trim();
        const searchInput = document.getElementById('residentSearchInput').value.toLowerCase().trim();
        const rows = document.querySelectorAll('.resident-row');

        rows.forEach(row => {
            const name = row.querySelector('.resident-name').textContent.toLowerCase();
            const purok = row.querySelector('.resident-purok').textContent.toLowerCase().trim();

            const matchesPurok = (selectedPurok === "") || (purok === selectedPurok);
            const matchesName = name.includes(searchInput);

            if (matchesPurok && matchesName) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }
</script>