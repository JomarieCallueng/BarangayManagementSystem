@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Staff Account Profile";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm p-4 text-center bg-white">
                    <div class="mb-3">
                        <i class="bi bi-person-workspace text-primary display-1"></i>
                    </div>
                    <h3 class="fw-bold text-dark">Barangay Staff Account</h3>
                    <p class="text-muted small">Official Desk & Operations Profile</p>

                    <hr>

                    <div class="text-start bg-light p-3 rounded mb-4 small">
                        <div class="mb-2"><strong>Role:</strong> Barangay Clerk / Staff</div>
                        <div class="mb-2"><strong>Email:</strong> staff@barangay.gov.ph</div>
                        <div><strong>Access Level:</strong> Limited Desk Operations (Encoding & Requests Only)</div>
                    </div>

                    <div class="d-flex gap-2 justify-content-center">
                        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Residents" class="btn btn-outline-primary btn-sm px-3">
                            <i class="bi bi-file-earmark-text"></i> Process Requests
                        </a>
                        <a asp-area="" asp-controller="Account" asp-action="Logout" class="btn btn-danger btn-sm px-3">
                            <i class="bi bi-box-arrow-left"></i> Sign Out
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
