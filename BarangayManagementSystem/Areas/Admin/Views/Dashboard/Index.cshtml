@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard - Barangay Admin Panel</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body {
            background-color: #f3f4f6;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .sidebar {
            background-color: #1e3a8a;
            min-height: 100vh;
            color: #ffffff;
            width: 240px;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 100;
        }

            .sidebar .nav-link {
                color: #93c5fd;
                font-size: 0.9rem;
                padding: 10px 20px;
                display: flex;
                align-items: center;
                border-radius: 0px;
                text-decoration: none;
                transition: all 0.2s;
            }

                .sidebar .nav-link i {
                    font-size: 1.1rem;
                    width: 25px;
                }

                .sidebar .nav-link:hover {
                    color: #ffffff;
                    background-color: rgba(255, 255, 255, 0.05);
                }

                .sidebar .nav-link.active {
                    color: #ffffff;
                    background-color: rgba(255, 255, 255, 0.1);
                    font-weight: 600;
                    border-left: 4px solid #ffffff;
                }

        .main-content {
            margin-left: 240px;
            min-height: 100vh;
        }

        .welcome-banner {
            background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
            border-radius: 12px;
            color: white;
            padding: 24px;
        }

        .stat-card {
            background-color: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 16px 20px;
            height: 100%;
        }

        .stat-icon-box {
            width: 42px;
            height: 42px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }

        .data-card {
            background-color: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 20px;
        }

        .shortcut-btn {
            border: none;
            border-radius: 8px;
            padding: 12px 20px;
            font-size: 0.85rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: opacity 0.2s;
        }

            .shortcut-btn:hover {
                opacity: 0.9;
            }
    </style>
</head>
<body>

    <div class="sidebar d-flex flex-column justify-content-between pb-3">
        <div>
            <div class="p-3 border-bottom border-white border-opacity-10 d-flex align-items-center gap-2">
                <i class="bi bi-shield-check fs-3"></i>
                <div>
                    <h6 class="fw-bold mb-0 lh-1">Barangay</h6>
                    <small class="text-white-50" style="font-size: 0.75rem;">Admin Panel</small>
                </div>
            </div>

            <ul class="nav flex-column mt-3">
                <li class="nav-item"><a class="nav-link active" href="/Admin/Dashboard/Index"><i class="bi bi-grid-fill me-2"></i> Dashboard</a></li>
                <li class="nav-item"><a class="nav-link" href="/Admin/Dashboard/Residents"><i class="bi bi-people me-2"></i> Residents</a></li>
                <li class="nav-item"><a class="nav-link" href="/Admin/Dashboard/Certificates"><i class="bi bi-file-earmark-text me-2"></i> Certificates</a></li>
                <li class="nav-item"><a class="nav-link" href="/Admin/Dashboard/Complaints"><i class="bi bi-chat-left-text me-2"></i> Complaints</a></li>
                <li class="nav-item"><a class="nav-link" href="#"><i class="bi bi-kanban me-2"></i> Projects</a></li>
                <li class="nav-item"><a class="nav-link" href="#"><i class="bi bi-exclamation-triangle me-2"></i> Disaster</a></li>
                <li class="nav-item"><a class="nav-link" href="#"><i class="bi bi-heart-pulse me-2"></i> Health</a></li>
                <li class="nav-item"><a class="nav-link" href="#"><i class="bi bi-leaf me-2"></i> Environment</a></li>
                <li class="nav-item"><a class="nav-link" href="#"><i class="bi bi-graph-up me-2"></i> Reports</a></li>
            </ul>
        </div>
        <div class="px-3 text-white-50" style="font-size: 0.7rem;">
            &copy; 2026 Barangay MIS
        </div>
    </div>

    <div class="main-content">
        <div class="bg-white border-bottom px-4 py-2 d-flex justify-content-between align-items-center shadow-sm">
            <h6 class="fw-bold text-dark mb-0">Dashboard</h6>
            <div class="d-flex align-items-center gap-3">
                <button class="btn position-relative p-1 text-secondary">
                    <i class="bi bi-bell fs-5"></i>
                    <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle"></span>
                </button>
                <div class="d-flex align-items-center gap-2 border-start ps-3">
                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                        <i class="bi bi-person text-secondary"></i>
                    </div>
                    <span class="small fw-semibold text-secondary">Administrator</span>
                </div>

                <a href="/Admin/Dashboard/Logout" class="btn btn-outline-danger btn-sm rounded px-2 py-1 ms-2 d-flex align-items-center gap-1">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </a>
            </div>
        </div>

        <div class="p-4">
            <div class="welcome-banner mb-3 d-flex justify-content-between align-items-center">
                <div>
                    <small class="text-white-50 text-uppercase fw-bold tracking-wider" style="font-size: 0.75rem;">Welcome back,</small>
                    <h4 class="fw-bold mb-2">Administrator!</h4>
                    <p class="mb-0 text-white-50 small" style="max-width: 500px;">This dashboard allows efficient monitoring and management of barangay operations, resident services, emergency response, and community programs.</p>
                </div>
                <div class="bg-white bg-opacity-10 rounded p-3 text-center border border-white border-opacity-10">
                    <small class="d-block text-white-50 small text-uppercase">Today</small>
                    <span class="fw-bold small"><i class="bi bi-calendar3 me-1"></i> Fri, Jun 26, 2026</span>
                </div>
            </div>

            <div class="alert alert-danger border-0 shadow-sm d-flex justify-content-between align-items-center py-2 px-3 mb-4 rounded-3" style="background-color: #fee2e2;">
                <div class="small text-danger fw-medium">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> <strong>2 active emergency alerts</strong> — Flood Warning in Purok 3 and Purok 4. Review immediately.
                </div>
                <a href="#" class="text-danger small fw-bold text-decoration-none">View <i class="bi bi-arrow-right"></i></a>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-2">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="text-muted small fw-medium">Total Residents</span>
                            <div class="stat-icon-box bg-primary bg-opacity-10 text-primary"><i class="bi bi-people"></i></div>
                        </div>
                        <h4 class="fw-bold mb-1 text-dark">5,230</h4>
                        <small class="text-success small" style="font-size: 0.75rem;">Registered</small>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="text-muted small fw-medium">Pending Complaints</span>
                            <div class="stat-icon-box bg-warning bg-opacity-10 text-warning"><i class="bi bi-chat-square-dots"></i></div>
                        </div>
                        <h4 class="fw-bold mb-1 text-dark">18</h4>
                        <small class="text-warning small" style="font-size: 0.75rem;">Needs attention</small>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="text-muted small fw-medium">Active Projects</span>
                            <div class="stat-icon-box bg-success bg-opacity-10 text-success"><i class="bi bi-activity"></i></div>
                        </div>
                        <h4 class="fw-bold mb-1 text-dark">7</h4>
                        <small class="text-muted small" style="font-size: 0.75rem;">In progress</small>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="stat-card">
                        <div class="col-md-12 d-flex justify-content-between align-items-start mb-2">
                            <span class="text-muted small fw-medium">Emergency Alerts</span>
                            <div class="stat-icon-box bg-danger bg-opacity-10 text-danger"><i class="bi bi-bell"></i></div>
                        </div>
                        <h4 class="fw-bold mb-1 text-dark">2</h4>
                        <small class="text-danger small" style="font-size: 0.75rem;">Active now</small>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="text-muted small fw-medium">Certificates Today</span>
                            <div class="stat-icon-box bg-info bg-opacity-10 text-info"><i class="bi bi-file-earmark-check"></i></div>
                        </div>
                        <h4 class="fw-bold mb-1 text-dark">35</h4>
                        <small class="text-muted small" style="font-size: 0.75rem;">Issued</small>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="text-muted small fw-medium">Vaccinated</span>
                            <div class="stat-icon-box bg-success bg-opacity-10 text-success"><i class="bi bi-heart-pulse"></i></div>
                        </div>
                        <h4 class="fw-bold mb-1 text-dark">4,100</h4>
                        <small class="text-muted small" style="font-size: 0.75rem;">Residents</small>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="data-card h-100">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold mb-0 text-dark">Recent Complaints</h6>
                            <a href="/Admin/Dashboard/Complaints" class="text-primary small text-decoration-none">View All</a>
                        </div>
                        <div class="d-flex flex-column gap-3">
                            @if (ViewBag.RecentComplaintsList != null)
                            {
                                foreach (var item in ViewBag.RecentComplaintsList)
                                {
                                    <div class="d-flex justify-content-between align-items-center border-bottom pb-2">
                                        <div>
                                            <p class="mb-0 fw-semibold small text-dark">@item.Title</p>
                                            <small class="text-muted d-block" style="font-size: 0.75rem;">@item.Resident</small>
                                        </div>
                                        @{
                                            string badgeClass = "bg-warning text-warning";
                                            if (item.Status == "Ongoing") badgeClass = "bg-primary text-primary";
                                            if (item.Status == "Resolved") badgeClass = "bg-success text-success";
                                        }
                                        <span class="badge @badgeClass bg-opacity-10 px-2 py-1 rounded small" style="font-size: 0.7rem;">@item.Status</span>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="data-card h-100">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold mb-0 text-dark">Certificates Issued Today</h6>
                            <a href="/Admin/Dashboard/Certificates" class="text-primary small text-decoration-none">View All</a>
                        </div>
                        <div class="d-flex flex-column gap-2 small">
                            <div class="d-flex justify-content-between py-2 border-bottom">
                                <div><span class="fw-medium text-dark">Ana Garcia</span> <small class="text-muted d-block" style="font-size: 0.75rem;">Barangay Clearance</small></div>
                                <span class="text-muted" style="font-size: 0.75rem;">9:15 AM</span>
                            </div>
                            <div class="d-flex justify-content-between py-2 border-bottom">
                                <div><span class="fw-medium text-dark">Roberto Lim</span> <small class="text-muted d-block" style="font-size: 0.7rem;">Residency Certificate</small></div>
                                <span class="text-muted" style="font-size: 0.75rem;">10:02 AM</span>
                            </div>
                            <div class="d-flex justify-content-between py-2 border-bottom">
                                <div><span class="fw-medium text-dark">Luz Manalo</span> <small class="text-muted d-block" style="font-size: 0.7rem;">Good Moral Certificate</small></div>
                                <span class="text-muted" style="font-size: 0.75rem;">11:30 AM</span>
                            </div>
                            <div class="d-flex justify-content-between py-1">
                                <div><span class="fw-medium text-dark">Carlos Cruz</span> <small class="text-muted d-block" style="font-size: 0.7rem;">Business Permit</small></div>
                                <span class="text-muted" style="font-size: 0.75rem;">1:45 PM</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="data-card h-100">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="fw-bold mb-0 text-dark">Project Progress</h6>
                            <a href="#" class="text-primary small text-decoration-none">View All</a>
                        </div>
                        <div class="d-flex flex-column gap-3 small">
                            <div>
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="fw-medium text-dark">Road Repair</span>
                                    <span class="text-muted">80%</span>
                                </div>
                                <div class="progress" style="height: 6px;"><div class="progress-bar bg-primary" style="width: 80%"></div></div>
                            </div>
                            <div>
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="fw-medium text-dark">Drainage Project</span>
                                    <span class="text-muted">45%</span>
                                </div>
                                <div class="progress" style="height: 6px;"><div class="progress-bar bg-primary" style="width: 45%"></div></div>
                            </div>
                            <div class="border-bottom pb-2">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="fw-medium text-dark">Street Lighting</span>
                                    <span class="text-muted">10%</span>
                                </div>
                                <div class="progress" style="height: 6px;"><div class="progress-bar bg-primary" style="width: 10%"></div></div>
                            </div>
                            <div class="pt-1 small text-success fw-medium">
                                <i class="bi bi-check-circle-fill me-1"></i> Feeding Program — Completed
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-3">
                    <a href="/Admin/Dashboard/Residents" class="shortcut-btn w-100 bg-primary bg-opacity-10 text-primary py-3 text-decoration-none"><i class="bi bi-person-plus-fill"></i> Manage Residents</a>
                </div>
                <div class="col-md-3">
                    <a href="/Admin/Dashboard/Certificates" class="shortcut-btn w-100 py-3 text-decoration-none" style="background-color: #e0f2fe; color: #0369a1;"><i class="bi bi-file-earmark-text-fill"></i> View Certificates</a>
                </div>
                <div class="col-md-3">
                    <a href="/Admin/Dashboard/Complaints" class="shortcut-btn w-100 py-3 text-decoration-none" style="background-color: #f3e8ff; color: #7c3aed;"><i class="bi bi-chat-left-text-fill"></i> View Complaints</a>
                </div>
                <div class="col-md-3">
                    <button class="shortcut-btn w-100 bg-danger bg-opacity-10 text-danger py-3" style="background-color: #fee2e2; color: #dc2626;"><i class="bi bi-shield-fire"></i> Disaster Response</button>
                </div>
            </div>

        </div>
    </div>

</body>
</html>