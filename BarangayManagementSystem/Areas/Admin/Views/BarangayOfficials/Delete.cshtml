@model BarangayCMS.Web.Areas.Admin.Models.BarangayOfficialViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Alisin ang Opisyal";
}

<div class="container mt-4" style="max-width: 500px;">
    <div class="card border-danger shadow">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0"><i class="bi bi-person-x-fill"></i> Tanggalin ang Opisyal</h4>
        </div>
        <div class="card-body text-center">
            <h5 class="mb-3">Sigurado ka bang nais mong burahin ang opisyal na ito sa listahan?</h5>

            <div class="alert alert-danger text-start">
                <strong>Pangalan:</strong> @Model.FullName <br />
                <strong>Posisyon:</strong> @Model.Position
            </div>
            <p class="text-muted small">Paalala: Mawawala ang kanyang lagda file at record sa database nang permanente.</p>
        </div>
        <div class="card-footer d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">I-cancel</a>
            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-4">Oo, Burahin</button>
            </form>
        </div>
    </div>
</div>