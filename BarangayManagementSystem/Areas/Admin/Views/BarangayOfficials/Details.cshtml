@model BarangayCMS.Web.Areas.Admin.Models.BarangayOfficialViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Impormasyon ng Opisyal";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0"><i class="bi bi-person-vcard"></i> Profile ng Opisyal</h4>
        </div>
        <div class="card-body">
            <div class="text-center mb-4">
                <div class="bg-light d-inline-block rounded-circle p-3 mb-2 border">
                    <i class="bi bi-person-badge text-secondary" style="font-size: 3rem;"></i>
                </div>
                <h3>@Model.FullName</h3>
                <span class="badge bg-primary fs-6">@Model.Position</span>
            </div>

            <hr />

            <dl class="row px-2">
                <dt class="col-sm-4 text-muted">Komite (Committee):</dt>
                <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Committee) ? "Walang Nakatalagang Komite" : Model.Committee)</dd>

                <dt class="col-sm-4 text-muted">Status:</dt>
                <dd class="col-sm-8">
                    @if (Model.IsActive)
                    {
                        <span class="text-success fw-bold"><i class="bi bi-circle-fill small"></i> Kasalukuyang Nakaupo</span>
                    }
                    else
                    {
                        <span class="text-danger fw-bold"><i class="bi bi-circle-fill small"></i> Tapos na ang Termino</span>
                    }
                </dd>

                <dt class="col-sm-4 text-muted mt-3">Digital Signature:</dt>
                <dd class="col-sm-8 mt-2">
                    @if (!string.IsNullOrEmpty(Model.SignaturePath))
                    {
                        <div class="p-2 border rounded bg-white" style="width: fit-content;">
                            <img src="~/uploads/signatures/@Model.SignaturePath" alt="Official Signature" style="max-height: 80px;" />
                        </div>
                    }
                    else
                    {
                        <span class="text-muted italic small">Walang na-upload na lagda.</span>
                    }
                </dd>
            </dl>
        </div>
        <div class="card-footer d-flex justify-content-between bg-white border-top-0">
            <a asp-action="Index" class="btn btn-secondary">Bumalik</a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil"></i> I-edit ang Profile</a>
        </div>
    </div>
</div>