@model BarangayCMS.Entities.CertificateType

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Magdagdag ng Sertipiko";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded p-4">
            <h3 class="fw-bold text-dark mb-3">
                <i class="bi bi-plus-circle text-primary me-2"></i>Bagong Sertipiko
            </h3>
            <p class="text-muted small">Ilagay ang detalye at i-upload ang template ng bagong dokumento na maaaring i-request ng mga residente.</p>
            <hr />

            <!-- 🌟 May enctype para sa pag-upload ng file -->
            <form action="/Admin/AdminCertificateTypes/Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <!-- Row para sa Pangalan at Presyo -->
                <div class="row mb-3">
                    <div class="col-md-8">
                        <label class="form-label fw-semibold">Pangalan ng Sertipiko / Clearance</label>
                        <input type="text" asp-for="CertificateName" name="CertificateName" id="CertificateName" class="form-control form-control-lg" placeholder="Hal. Barangay Clearance" required />
                        <span asp-validation-for="CertificateName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Presyo o Halaga (₱)</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white">₱</span>
                            <input type="number" asp-for="Price" name="Price" id="Price" step="0.01" class="form-control" placeholder="0.00" required />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                </div>

                <!-- File Upload Input -->
                <div class="mb-4">
                    <label class="form-label fw-semibold text-primary">
                        <i class="bi bi-file-earmark-word me-1"></i> I-upload ang Word Template (.docx)
                    </label>
                    <input type="file" name="TemplateFile" id="TemplateFile" class="form-control form-control-lg" accept=".docx" required />
                    <div class="form-text text-muted small mt-2">
                        Siguraduhing Microsoft Word (.docx) format ang iyong i-u-upload na template.
                    </div>
                </div>

                <!-- Buttons -->
                <div class="d-flex gap-2 justify-content-end border-top pt-3">
                    <a href="/Admin/AdminCertificateTypes" class="btn btn-outline-secondary px-4">Bumalik</a>
                    <button type="submit" class="btn btn-primary px-4">I-save ang Sertipiko</button>
                </div>
            </form>
        </div>
    </div>
</div>