@model BarangayCMS.Web.Areas.Admin.Models.ComplaintViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "File Complaint";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Complaints" asp-action="Index">Complaints</a></li>
                <li class="breadcrumb-item active" aria-current="page">New Incident</li>
            </ol>
        </nav>

        <div class="card border-0 shadow-sm rounded-3 mt-3">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-file-earmark-medical me-2"></i>Barangay Blotter Entry Form</h4>
            </div>
            <div class="card-body p-4">
                <form asp-area="Admin" asp-controller="Complaints" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Complainant Dropdown -->
                    <div class="mb-3">
                        <label asp-for="ResidentId" class="form-label fw-bold">Select Complainant (Resident)</label>
                        <select asp-for="ResidentId" asp-items="Model.ResidentList" class="form-select form-select-lg">
                            <option value="">-- Choose Resident from Database --</option>
                        </select>
                        <span asp-validation-for="ResidentId" class="text-danger small"></span>
                    </div>

                    <!-- Subject Input -->
                    <div class="mb-3">
                        <label asp-for="Subject" class="form-label fw-bold">Nature of Incident / Subject</label>
                        <input asp-for="Subject" class="form-control form-control-lg" placeholder="e.g., Noise Complaint, Boundary Dispute, Physical Altercation" />
                        <span asp-validation-for="Subject" class="text-danger small"></span>
                    </div>

                    <!-- Narrative Details -->
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">Narrative & Incident Details</label>
                        <textarea asp-for="Description" class="form-control" rows="5" placeholder="Write down structural specifics, names of witnesses, and statements..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <!-- Date and Status Row -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DateSubmitted" class="form-label fw-bold">Date of Logging</label>
                            <input asp-for="DateSubmitted" class="form-control" type="datetime-local" />
                            <span asp-validation-for="DateSubmitted" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Status" class="form-label fw-bold">Initial Entry Status</label>
                            <select asp-for="Status" class="form-select">
                                <option value="Pending">Pending Audit</option>
                                <option value="Assigned">Assigned to Mediation</option>
                                <option value="Resolved">Closed / Resolved</option>
                            </select>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <!-- Buttons -->
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-area="Admin" asp-controller="Complaints" asp-action="Index" class="btn btn-light px-4">Cancel</a>
                        <button type="submit" class="btn btn-primary px-5 shadow-sm">Save Record</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}