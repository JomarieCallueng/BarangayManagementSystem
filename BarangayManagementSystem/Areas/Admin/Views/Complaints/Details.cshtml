@model BarangayCMS.Web.Areas.Admin.Models.ComplaintViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Case Details";
}

<div class="container mt-4" style="max-width: 750px;">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-info text-white py-3" style="background-color: #17a2b8 !important;">
            <h4 class="mb-0 fw-bold"><i class="bi bi-file-earmark-text me-2"></i>Complaint Log Ledger Record Summary</h4>
        </div>
        <div class="card-body p-4">
            <table class="table table-borderless fs-5">
                <tr>
                    <td class="fw-bold text-muted" style="width: 35%;">Complainant:</td>
                    <td class="fw-semibold text-dark">
                        @if (Model.Subject != null && Model.Subject.StartsWith("CMP"))
                        {
                            <i class="bi bi-globe me-1 text-primary"></i> 
                            @Model.ResidentFullName
                            <span class="badge bg-info text-dark fs-6 ms-2">Online Form</span>
                        }
                        else
                        {
                            @Model.ResidentFullName
                        }
                    </td>
                </tr>
                <tr>
                    <td class="fw-bold text-muted">Subject Head:</td>
                    <td class="fw-bold text-primary">@Model.Subject</td>
                </tr>
                <tr>
                    <td class="fw-bold text-muted">Date Submitted:</td>
                    <td>@Model.DateSubmitted.ToString("MMMM dd, yyyy")</td>
                </tr>
                <tr>
                    <td class="fw-bold text-muted">Track State Status:</td>
                    <td><span class="badge bg-dark px-3 py-2">@Model.Status</span></td>
                </tr>
            </table>

            <div class="mt-4">
                <p class="fw-bold text-muted mb-2">Narrative & Statements Summary Details:</p>
                <div class="p-3 bg-light rounded border" style="min-height: 100px;">
                    @Model.Description
                </div>
            </div>

            <!-- 🔑 BUTTONS -->
            <div class="d-flex justify-content-between mt-4">
                <a asp-area="Admin" asp-controller="Complaints" asp-action="Index" class="btn btn-secondary px-4">Back to Registry</a>
                <div class="d-flex gap-2">
                    <a asp-area="Admin" asp-controller="Complaints" asp-action="UpdateStatus" asp-route-id="@Model.Id" class="btn btn-outline-primary px-4">Shift State</a>
                    <a asp-area="Admin" asp-controller="Complaints" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning text-dark fw-semibold px-4">Edit Records</a>
                </div>
            </div>
        </div>
    </div>
</div>