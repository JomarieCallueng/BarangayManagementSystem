@model BarangayCMS.Web.Areas.Admin.Models.ComplaintViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Expunge Complaint File Entry";
}

<div class="container mt-4" style="max-width: 550px;">
    <div class="card border-danger shadow">
        <div class="card-header bg-danger text-white py-3">
            <h4 class="mb-0 fw-bold"><i class="bi bi-trash-fill me-2"></i>Expunge Complaint File Entry</h4>
        </div>
        <div class="card-body p-4">
            <h5 class="text-center text-dark mb-4 fw-semibold">Are you absolutely sure you want to drop and erase this record summary tracking entry?</h5>

            <div class="p-3 rounded mb-3" style="background-color: #f8d7da; border: 1px solid #f5c6cb;">
                <p class="mb-1 text-danger"><strong>Filer Faction:</strong> @Model.ResidentFullName</p>
                <p class="mb-1 text-danger"><strong>Subject Matter:</strong> @Model.Subject</p>
                <p class="mb-0 text-danger"><strong>Current Track Status:</strong> @Model.Status</p>
            </div>

            <p class="text-muted text-center small mb-4">Removing active incident records compromises community record legal logs history consistency audits.</p>

            <form asp-area="Admin" asp-controller="Complaints" asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-center gap-3">
                    <a asp-area="Admin" asp-controller="Complaints" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary px-4">Cancel Process</a>
                    <button type="submit" class="btn btn-danger px-4 fw-bold">Confirm Expunge</button>
                </div>
            </form>
        </div>
    </div>
</div>