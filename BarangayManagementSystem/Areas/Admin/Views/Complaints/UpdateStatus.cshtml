@model BarangayCMS.Web.Areas.Admin.Models.ComplaintViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Update Legal State Status";
}

<div class="container mt-4" style="max-width: 550px;">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0 fw-bold"><i class="bi bi-arrow-left-right me-2"></i>Set Hearing / Tracking Resolution Status</h4>
        </div>
        <div class="card-body p-4">
            <p class="text-muted small">Modify the resolution stage tracking metrics step for this dispute narrative instance.</p>

            <div class="p-3 bg-light rounded border mb-4">
                <p class="mb-1"><strong>Subject:</strong> @Model.Subject</p>
                <p class="mb-0"><strong>Current State:</strong> <span class="text-primary fw-bold">@Model.Status</span></p>
            </div>

            <form asp-area="Admin" asp-controller="Complaints" asp-action="UpdateStatus" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="mb-4">
                    <label class="form-label fw-bold">Transition Destination Status</label>
                    <select asp-for="Status" class="form-select">
                        <option value="Pending">Pending</option>
                        <option value="Assigned">Assigned</option>
                        <option value="Investigation">Investigation</option>
                        <option value="Resolved">Resolved</option>
                        <option value="Dismissed">Dismissed</option>
                    </select>
                </div>

                <div class="d-flex gap-3 justify-content-between">
                    <a asp-area="Admin" asp-controller="Complaints" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary px-4">Discard</a>
                    <button type="submit" class="btn btn-success px-4 fw-bold">Authorize State Transition</button>
                </div>
            </form>
        </div>
    </div>
</div>