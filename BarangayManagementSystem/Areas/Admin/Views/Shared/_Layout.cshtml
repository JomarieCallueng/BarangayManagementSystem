@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Barangay Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
            body {
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                background-color: #f4f6f9;
            }

            .sidebar {
                width: 260px;
                min-height: 100vh;
                background-color: #1a365d;
                box-shadow: 2px 0 5px rgba(0,0,0,0.05);
            }

                .sidebar .nav-link {
                    color: rgba(255, 255, 255, 0.7);
                    padding: 0.75rem 1rem;
                    border-radius: 4px;
                    margin-bottom: 0.1rem;
                    font-size: 0.9rem;
                    text-decoration: none;
                    display: block;
                }

                    .sidebar .nav-link:hover {
                        color: #fff;
                        background-color: rgba(255, 255, 255, 0.05);
                    }

                .sidebar .nav-link-logout:hover {
                    color: #ff8787 !important;
                    background-color: rgba(220, 53, 69, 0.1) !important;
                }
    </style>
</head>
<body>
    <div class="d-flex">
        <!-- MASTER SIDEBAR -->
        <div class="sidebar text-white p-3 d-flex flex-column min-vh-100">
            <div class="d-flex align-items-center mb-4 px-2 pt-2">
                <i class="bi bi-shield-check text-warning fs-3 me-2"></i>
                <div>
                    <h6 class="fw-bold mb-0">Barangay Admin</h6>
                    <small class="text-white-50" style="font-size: 0.75rem;">Core Portal</small>
                </div>
            </div>

            <ul class="nav flex-column mb-auto">
                <li><a href="/Admin/Dashboard" class="nav-link text-white"><i class="bi bi-grid-fill me-2"></i> Dashboard</a></li>
                <li><a href="/Admin/Residents" class="nav-link text-white"><i class="bi bi-people me-2"></i> Residents</a></li>
                <li><a href="/Admin/Certificates" class="nav-link text-white"><i class="bi bi-file-earmark-text me-2"></i> Certificates</a></li>
                <li><a href="/Admin/Complaints" class="nav-link text-white"><i class="bi bi-chat-left-text me-2"></i> Complaints</a></li>
                <li><a href="/Admin/Projects" class="nav-link text-white"><i class="bi bi-kanban me-2"></i> Projects</a></li>
                <li><a href="/Admin/Budget" class="nav-link text-white"><i class="bi bi-cash-coin me-2"></i> Budget Tracker</a></li>
                <li><a href="/Admin/Disaster" class="nav-link text-white"><i class="bi bi-shield-exclamation me-2"></i> Disaster Risk</a></li>
                <li><a href="/Admin/Health" class="nav-link text-white"><i class="bi bi-heart-pulse me-2"></i> Health Center</a></li>
                <li><a href="/Admin/Environment" class="nav-link text-white"><i class="bi bi-tree me-2"></i> Environment</a></li>
                <li><a href="/Admin/BarangayOfficials" class="nav-link text-white"><i class="bi bi-person-badge me-2"></i> Officials</a></li>
                <li><a href="/Admin/Announcements" class="nav-link text-white"><i class="bi bi-megaphone me-2"></i> Announcements</a></li>
                <li><a href="/Admin/Reports" class="nav-link text-white"><i class="bi bi-graph-up-arrow me-2"></i> Reports</a></li>
                <li><a href="/Admin/Users" class="nav-link text-white"><i class="bi bi-person-gear me-2"></i> User Accounts</a></li>
                <li><a href="/Admin/Settings" class="nav-link text-white"><i class="bi bi-gear me-2"></i> Settings</a></li>

                <li class="mt-3 border-top border-secondary pt-2">
                    <a href="#" data-bs-toggle="modal" data-bs-target="#logoutModal" class="nav-link nav-link-logout text-danger fw-semibold">
                        <i class="bi bi-box-arrow-right me-2"></i> Log Out
                    </a>
                </li>
            </ul>

            <div class="pt-2 border-top border-secondary text-center small text-white-50">© 2026 Barangay MIS</div>
        </div>

        <!-- MAIN BODY CONTENT -->
        <div class="flex-fill p-4">
            @RenderBody()
        </div>
    </div>

    <!-- 🌐 BOOTSTRAP MODAL PARA SA LOG OUT CONFIRMATION -->
    <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-light border-0 pt-4 px-4">
                    <h5 class="modal-title fw-bold text-dark" id="logoutModalLabel">
                        <i class="bi bi-box-arrow-right text-danger me-2"></i> Sign Out
                    </h5>
                    <button type="button" class="btn-close" data-bs-shadow="none" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body px-4 py-3">
                    <p class="text-secondary mb-0">Sigurado ka bang nais mong mag-log out sa system?</p>
                </div>
                <div class="modal-footer border-0 pb-4 px-4 d-flex gap-2">
                    <!-- NO BUTTON -->
                    <button type="button" class="btn btn-light border flex-fill fw-medium" data-bs-dismiss="modal">Hindi / No</button>

                    <!-- FIX FORM (Controller Route) -->
                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="flex-fill d-flex m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger w-100 fw-medium">Oo / Yes</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>