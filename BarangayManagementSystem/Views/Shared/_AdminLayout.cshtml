<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel | BMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">

    <div class="d-flex" id="wrapper">
        <!-- Sidebar Navigation -->
        <div class="bg-dark-blue text-white" id="sidebar-wrapper" style="min-width: 250px; min-height: 100vh;">
            <div class="sidebar-heading p-4 border-bottom border-white border-opacity-10">
                <a class="text-white text-decoration-none d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shield-lock me-2 fs-4 text-emerald"></i>
                    <span class="fw-bold fs-6">BMS Admin</span>
                </a>
            </div>
            <div class="list-group list-group-flush px-2 py-3">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Residents"
                   class="list-group-item list-group-item-action bg-transparent text-white border-0 rounded-2 py-2 px-3 mb-1 hover-white small">
                    <i class="bi bi-people me-2"></i> Residents Record
                </a>
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Certificates"
                   class="list-group-item list-group-item-action bg-transparent text-white border-0 rounded-2 py-2 px-3 mb-1 hover-white small">
                    <i class="bi bi-file-earmark-text me-2"></i> Request Approvals
                </a>
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Complaints"
                   class="list-group-item list-group-item-action bg-transparent text-white border-0 rounded-2 py-2 px-3 mb-1 hover-white small">
                    <i class="bi bi-chat-square-quote me-2"></i> Blotter Cases
                </a>
                <hr class="border-white border-opacity-10 my-2" />
                <a asp-area="" asp-controller="Home" asp-action="Index"
                   class="list-group-item list-group-item-action bg-transparent text-white-50 border-0 rounded-2 py-2 px-3 small hover-white">
                    <i class="bi bi-box-arrow-left me-2"></i> Back to Main Portal
                </a>
            </div>
        </div>

        <!-- Page Content Wrapper -->
        <div id="page-content-wrapper" class="w-100">
            <!-- Top Navbar for Admin Info -->
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom px-4 py-3 shadow-sm">
                <div class="container-fluid p-0">
                    <span class="navbar-text fw-semibold text-dark-blue small">
                        <i class="bi bi-calendar3 me-1"></i> System Session Active
                    </span>
                    <div class="dropdown">
                        <button class="btn btn-light btn-sm dropdown-toggle fw-semibold" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i> Authorized Officer
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2">
                            <li><a class="dropdown-item small py-2" href="#"><i class="bi bi-gear me-2 text-muted"></i>Settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item small py-2 text-danger" href="#"><i class="bi bi-power me-2"></i>Sign Out</a></li>
                        </ul>
                    </div>
                </div>
            </nav>

            <!-- Dynamic View Injections -->
            <main class="p-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
