<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Barangay Management System</title>
    <link class="nav-link" rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @* Loaded in <head>, before the body paints, so the saved palette is applied with no flash of the default theme. *@
    <script src="~/js/theme-switcher.js" asp-append-version="true"></script>
</head>
<body>
    @{
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        var currentArea = ViewContext.RouteData.Values["Area"]?.ToString();
    }

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark-blue px-4 py-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shield-check me-2 fs-3"></i>
                    <div>
                        <span class="fw-bold d-block lh-1 fs-5">Barangay</span>
                        <small class="text-white-50 fs-7">Management System</small>
                    </div>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between" id="navbarNav">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link px-3 @(currentController == "Home" && currentAction == "Index" ? "active" : "")"
                               asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <!-- 🗂️ DROPDOWN MENU PARA SA MGA RESIDENTE -->
                        <!-- 🌟 INAYOS: Idinagdag ang "Announcement" at "DisasterPreparedness" sa Active state check -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle px-3 @(currentController == "CertificateRequest" || currentController == "Complaint" || currentController == "Announcement" || currentController == "DisasterPreparedness" ? "active" : "")"
                               href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Modules
                            </a>
                            <ul class="dropdown-menu shadow border-0 rounded-3 mt-2">
                                <!-- 📄 ONLINE SERVICES SECTION -->
                                <li><h6 class="dropdown-header text-uppercase text-muted fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">Online Services</h6></li>
                                <li>
                                    <!-- 🔗 Link para sa Certificate Request form -->
                                    <a class="dropdown-item py-2 px-3 small d-flex align-items-center gap-2" asp-area="" asp-controller="CertificateRequest" asp-action="Create">
                                        <i class="bi bi-file-earmark-text text-primary"></i> Request Certificate
                                    </a>
                                </li>
                                <li>
                                    <!-- 🔗 Link para sa Complaint Form -->
                                    <a class="dropdown-item py-2 px-3 small d-flex align-items-center gap-2" asp-area="" asp-controller="Complaint" asp-action="Create">
                                        <i class="bi bi-chat-left-text text-warning"></i> File a Complaint
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider opacity-50"></li>

                                <!-- 📢 INFORMATION SECTION -->
                                <li><h6 class="dropdown-header text-uppercase text-muted fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">Information</h6></li>
                                <li>
                                    <!-- 🌟 INAYOS: Itinuro sa tamang "Announcement" Controller at "Index" Action -->
                                    <a class="dropdown-item py-2 px-3 small d-flex align-items-center gap-2" asp-area="" asp-controller="Announcement" asp-action="Index">
                                        <i class="bi bi-megaphone text-success"></i> Announcements
                                    </a>
                                </li>
                                <li>
                                    <!-- 🌟 INAYOS: Inihanda para sa "DisasterPreparedness" Controller at "Index" Action -->
                                    <a class="dropdown-item py-2 px-3 small d-flex align-items-center gap-2" asp-area="" asp-controller="DisasterPreparedness" asp-action="Index">
                                        <i class="bi bi-exclamation-triangle text-danger"></i> Disaster Preparedness
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-3 @(currentController == "Home" && currentAction == "Contact" ? "active" : "")"
                               asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>
                        </li>
                    </ul>
                    <div class="d-flex gap-2">
                        <!-- 🌟 INAYOS: Emergency Alerts Link ay nakaturo na sa Announcement/Index -->
                        <a asp-area="" asp-controller="Announcement" asp-action="Index" fragment="emergency-section" class="btn btn-success btn-sm px-3 rounded fw-bold text-white bg-emerald">
                            Emergency Alerts
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="min-vh-100 pb-5">
        @RenderBody()
    </main>

    <!-- 🌐 PUBLIC FOOTER SECTION -->
    <footer class="bg-dark-blue text-white pt-5 pb-3 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-5">
                    <h5 class="fw-bold mb-3"><i class="bi bi-shield-check me-2"></i>Barangay Management System</h5>
                    <p class="text-white-50 small pe-md-5">A centralized digital platform improving governance, public service delivery, and community welfare.</p>
                </div>
                <div class="col-md-3">
                    <h6 class="text-uppercase fw-bold text-muted small mb-3">Quick Links</h6>
                    <ul class="list-unstyled text-white-50 small lh-lg">
                        <li><a asp-area="" asp-controller="CertificateRequest" asp-action="Create" class="text-reset text-decoration-none hover-white">Request Certificate</a></li>
                        <li><a asp-area="" asp-controller="Complaint" asp-action="Create" class="text-reset text-decoration-none hover-white">File a Complaint</a></li>
                        <!-- 🌟 INAYOS: Footer Links itinama ang Controller at Action -->
                        <li><a asp-area="" asp-controller="Announcement" asp-action="Index" class="text-reset text-decoration-none hover-white">Barangay Announcements</a></li>
                        <li><a asp-area="" asp-controller="DisasterPreparedness" asp-action="Index" class="text-reset text-decoration-none hover-white">Disaster Response</a></li>
                        <li><a asp-area="" asp-controller="Account" asp-action="Login" class="text-reset text-decoration-none hover-white fw-semibold text-info"><i class="bi bi-box-arrow-in-right me-1"></i>Staff Portal Login</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-uppercase fw-bold text-muted small mb-3">Contact Info</h6>
                    <p class="text-white-50 small mb-2"><i class="bi bi-telephone me-2"></i> 0912-345-6789</p>
                    <p class="text-white-50 small mb-2"><i class="bi bi-envelope me-2"></i> barangay@email.com</p>
                    <p class="text-white-50 small"><i class="bi bi-clock me-2"></i> Mon–Fri, 8:00 AM – 5:00 PM</p>
                </div>
            </div>
            <hr class="border-white border-opacity-10 my-4" />
            <div class="text-center text-white-50 small">
                &copy; 2026 Comprehensive Barangay Management and Service System. All Rights Reserved.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>