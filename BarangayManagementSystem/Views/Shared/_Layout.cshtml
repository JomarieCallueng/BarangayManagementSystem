<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Barangay Management System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    @{
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    }

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark-blue px-4 py-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shield-check me-2 fs-3"></i>
                    <div>
                        <span class="fw-bold d-block lh-1 fs-5">Barangay</span>
                        <small class="text-white-50 fs-7">Management System</small>
                    </div>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between" id="navbarNav">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link px-3 @(currentController == "Home" && currentAction == "Index" ? "active" : "")"
                               asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle px-3 @(currentController == "Modules" ? "active" : "")"
                               href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Modules
                            </a>
                            <ul class="dropdown-menu shadow-sm border-0 rounded-3 mt-2">
                                <li><a class="dropdown-item py-2 px-3 small" asp-controller="Modules" asp-action="ResidentInformation">Resident Information</a></li>
                                <li><a class="dropdown-item py-2 px-3 small" asp-controller="Modules" asp-action="CertificatesPermits">Certificates & Permits</a></li>
                                <li><a class="dropdown-item py-2 px-3 small" asp-controller="Modules" asp-action="ComplaintsDisputes">Complaints & Disputes</a></li>
                                <li><a class="dropdown-item py-2 px-3 small" asp-controller="Modules" asp-action="Announcements">Announcements</a></li>
                                <li><a class="dropdown-item py-2 px-3 small" asp-controller="Modules" asp-action="BudgetProjects">Budget & Projects</a></li>
                                <li><a class="dropdown-item py-2 px-3 small" asp-controller="Modules" asp-action="DisasterPreparedness">Disaster Preparedness</a></li>
                                <li><a class="dropdown-item py-2 px-3 small" asp-controller="Modules" asp-action="HealthWelfare">Health & Welfare</a></li>
                                <li><a class="dropdown-item py-2 px-3 small" asp-controller="Modules" asp-action="EnvironmentalManagement">Environmental Management</a></li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-3 @(currentController == "Home" && currentAction == "Contact" ? "active" : "")"
                               asp-controller="Home" asp-action="Contact">Contact</a>
                        </li>
                    </ul>
                    <div class="d-flex gap-2">
                        <a asp-controller="Modules" asp-action="Announcements" fragment="emergency-section" class="btn btn-success btn-sm px-3 rounded fw-bold text-white bg-emerald">
                            Emergency Alerts
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="min-vh-100 pb-5">
        @RenderBody()
    </main>

    <footer class="bg-dark-blue text-white pt-5 pb-3 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-5">
                    <h5 class="fw-bold mb-3"><i class="bi bi-shield-check me-2"></i>Barangay Management System</h5>
                    <p class="text-white-50 small pe-md-5">A centralized digital platform improving governance, public service delivery, and community welfare.</p>
                </div>
                <div class="col-md-3">
                    <h6 class="text-uppercase fw-bold text-muted small mb-3">Quick Links</h6>
                    <ul class="list-unstyled text-white-50 small lh-lg">
                        <li><a asp-controller="Modules" asp-action="ResidentInformation" class="text-reset text-decoration-none hover-white">Residents</a></li>
                        <li><a asp-controller="Modules" asp-action="CertificatesPermits" class="text-reset text-decoration-none hover-white">Certificates</a></li>
                        <li><a asp-controller="Modules" asp-action="ComplaintsDisputes" class="text-reset text-decoration-none hover-white">Complaints</a></li>
                        <li><a asp-controller="Modules" asp-action="DisasterPreparedness" class="text-reset text-decoration-none hover-white">Disaster Response</a></li>
                        <li><a asp-controller="Modules" asp-action="HealthWelfare" class="text-reset text-decoration-none hover-white">Health Services</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-uppercase fw-bold text-muted small mb-3">Contact Info</h6>
                    <p class="text-white-50 small mb-2"><i class="bi bi-telephone me-2"></i> 0912-345-6789</p>
                    <p class="text-white-50 small mb-2"><i class="bi bi-envelope me-2"></i> barangay@email.com</p>
                    <p class="text-white-50 small"><i class="bi bi-clock me-2"></i> Mon–Fri, 8:00 AM – 5:00 PM</p>
                </div>
            </div>
            <hr class="border-white border-opacity-10 my-4" />
            <div class="text-center text-white-50 small">
                &copy; 2026 Comprehensive Barangay Management and Service System. All Rights Reserved.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>