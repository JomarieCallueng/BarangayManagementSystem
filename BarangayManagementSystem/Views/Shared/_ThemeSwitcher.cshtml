@*
    Floating preset switcher. Rendered on the Home page only — the choice it
    saves is persisted in localStorage and applies across every page.
*@
<button type="button"
        class="theme-fab"
        data-theme-fab
        aria-expanded="false"
        aria-controls="themePanel"
        aria-label="Change site appearance"
        title="Change site appearance">
    <i class="bi bi-palette-fill" aria-hidden="true"></i>
</button>

<div class="theme-panel"
     id="themePanel"
     data-theme-panel
     data-open="false"
     role="radiogroup"
     aria-label="Site appearance">

    <p class="theme-panel__title">Appearance</p>

    <button type="button" class="theme-option" data-preset="civic" role="radio" aria-checked="true">
        <span class="theme-option__swatch" aria-hidden="true">
            <span style="background:#0d1e3d"></span>
            <span style="background:#16a34a"></span>
            <span style="background:#f1f5f9"></span>
        </span>
        <span>
            <span class="theme-option__name">Civic Navy</span>
            <span class="theme-option__meta">Classic layout &middot; 4-column grid</span>
        </span>
        <i class="bi bi-check-circle-fill theme-option__check" aria-hidden="true"></i>
    </button>

    <button type="button" class="theme-option" data-preset="coastal" role="radio" aria-checked="false">
        <span class="theme-option__swatch" aria-hidden="true">
            <span style="background:#0f766e"></span>
            <span style="background:#f59e0b"></span>
            <span style="background:#fdfcf7"></span>
        </span>
        <span>
            <span class="theme-option__name">Coastal Teal</span>
            <span class="theme-option__meta">Split hero &middot; 2-column cards</span>
        </span>
        <i class="bi bi-check-circle-fill theme-option__check" aria-hidden="true"></i>
    </button>

    <button type="button" class="theme-option" data-preset="midnight" role="radio" aria-checked="false">
        <span class="theme-option__swatch" aria-hidden="true">
            <span style="background:#0b1120"></span>
            <span style="background:#6366f1"></span>
            <span style="background:#151d2e"></span>
        </span>
        <span>
            <span class="theme-option__name">Midnight Slate</span>
            <span class="theme-option__meta">Compact dark &middot; list rows</span>
        </span>
        <i class="bi bi-check-circle-fill theme-option__check" aria-hidden="true"></i>
    </button>
</div>

@* The host view is responsible for calling BmsTheme.initSwitcher() in its
   Scripts section — Razor partials cannot define sections themselves. *@
