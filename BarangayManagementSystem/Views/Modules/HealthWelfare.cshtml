@using BarangayManagementSystem.Models.ViewModels
@model HealthWelfarePageViewModel
@{
    ViewData["Title"] = "Health & Welfare Management";
}

<section class="hero-section text-white py-5 px-4 mb-4 shadow-sm">
    <div class="container py-2">
        <div class="d-flex align-items-center gap-3">
            <div class="p-3 bg-white bg-opacity-10 rounded-3 border border-white border-opacity-25 text-white">
                <i class="bi bi-heart-pulse fs-2"></i>
            </div>
            <div>
                <span class="badge bg-emerald text-white rounded-pill mb-1 px-3 py-1.5 fw-bold text-uppercase tracing-wider small-title-label">Module 7</span>
                <h1 class="h2 fw-bold mb-1">Health & Welfare</h1>
                <p class="text-white-50 mb-0">Manages patient consultations, monitoring of vital medical assets, and health center outreach schedules.</p>
            </div>
        </div>
    </div>
</section>

<div class="container pb-5">

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center gap-3">
                <div class="p-3 bg-warning bg-opacity-10 text-warning rounded-3"><i class="bi bi-person-lines-fill fs-3"></i></div>
                <div>
                    <h3 class="fw-bold text-dark-blue mb-0">@Model.PendingConsultations</h3>
                    <small class="text-secondary fw-semibold">Pending Consultations</small>
                    <span class="d-block text-muted small-title-label mt-1">Awaiting checkup</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center gap-3">
                <div class="p-3 bg-primary bg-opacity-10 text-primary rounded-3"><i class="bi bi-people fs-3"></i></div>
                <div>
                    <h3 class="fw-bold text-dark-blue mb-0">@Model.TotalPatientsToday</h3>
                    <small class="text-secondary fw-semibold">Patients Served Today</small>
                    <span class="d-block text-success small-title-label mt-1">● Active Center Logs</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center gap-3">
                <div class="p-3 bg-success bg-opacity-10 text-success rounded-3"><i class="bi bi-calendar-event fs-3"></i></div>
                <div>
                    <h3 class="fw-bold text-dark-blue mb-0" style="font-size: 1.35rem;">@Model.NextProgramDate</h3>
                    <small class="text-secondary fw-semibold">Next: @Model.NextProgramName</small>
                    <span class="d-block text-muted small-title-label mt-1">Community Outreach</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100">
                <h6 class="fw-bold text-dark-blue mb-4 pb-1 border-bottom border-light">System Features</h6>
                <div class="d-flex flex-column gap-3 text-secondary">
                    @foreach (var feature in Model.SystemFeatures)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-check-circle-fill text-success"></i> <span>@feature</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-3 bg-white overflow-hidden h-100">
                <div class="p-3 border-bottom border-light">
                    <h6 class="fw-bold text-dark-blue mb-0">Medical Supplies & Medicine Stocks</h6>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle text-secondary mb-0 table-hover-custom">
                        <thead class="bg-light text-dark fw-bold border-bottom">
                            <tr>
                                <th class="ps-4 py-3 fw-bold text-dark fs-7">Item Description</th>
                                <th class="py-3 fw-bold text-dark fs-7 text-center">Available Stock</th>
                                <th class="pe-4 py-3 fw-bold text-dark fs-7 text-center w-150">Status</th>
                            </tr>
                        </thead>
                        <tbody class="border-top-0">
                            @foreach (var item in Model.MedicalInventory)
                            {
                                <tr>
                                    <td class="ps-4 py-3">
                                        <span class="text-dark fw-bold d-block">@item.ItemName</span>
                                        <small class="text-muted text-uppercase font-monospace" style="font-size: 0.7rem;">@item.Category</small>
                                    </td>
                                    <td class="py-3 text-center text-dark font-monospace fw-semibold">@item.StockAvailable.ToString("N0")</td>
                                    <td class="pe-4 py-3 text-center">
                                        @if (item.Status == "In Stock")
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1.5 fs-8">In Stock</span>
                                        }
                                        else if (item.Status == "Low Stock")
                                        {
                                            <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3 py-1.5 fs-8">Low Stock</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-1.5 fs-8">Out of Stock</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>