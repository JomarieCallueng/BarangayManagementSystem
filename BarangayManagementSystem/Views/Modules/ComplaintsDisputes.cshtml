@model BarangayManagementSystem.Models.ComplaintsPageViewModel
@{
    ViewData["Title"] = "Complaints and Dispute Resolution";
}

<style>
    /* Custom utility classes para tumpak na sumunod sa Module 2 scheme niyo */
    .bg-dark-blue {
        background-color: #0d2353 !important;
    }

    .text-dark-blue {
        color: #0d2353 !important;
    }

    .fs-7 {
        font-size: 0.875rem !important;
    }

    .fs-8 {
        font-size: 0.75rem !important;
    }

    .tracking-tight {
        letter-spacing: -0.5px;
    }
</style>

<div class="container-fluid px-0 pb-5">

    <div class="hero-section text-white py-5 px-4 px-md-5 mb-5 shadow-sm bg-dark-blue mt-0">
        <div class="d-flex align-items-center">
            <div class="bg-white bg-opacity-10 p-3 rounded-3 me-3 d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                <i class="bi bi-chat-left-text fs-2"></i>
            </div>
            <div>
                <span class="badge bg-success text-white mb-1 fw-bold text-uppercase px-2 py-1 fs-8">Module 3</span>
                <h2 class="fw-bold m-0 tracking-tight">Complaints and Dispute Resolution</h2>
                <p class="text-white-50 m-0 small mt-1">Records and tracks complaints, incidents, and disputes within the barangay.</p>
            </div>
        </div>
    </div>

    <div class="px-4 px-md-5">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center">
                    <div class="bg-warning bg-opacity-10 text-warning p-3 rounded-3 me-4 d-flex align-items-center justify-content-center" style="width: 56px; height: 56px;">
                        <i class="bi bi-exclamation-circle fs-3"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold m-0 text-dark lh-1 mb-1">6</h3>
                        <p class="text-secondary m-0 fw-semibold small">Pending Cases</p>
                        <small class="text-muted fs-7">Awaiting action</small>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center">
                    <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-3 me-4 d-flex align-items-center justify-content-center" style="width: 56px; height: 56px;">
                        <i class="bi bi-journal-text fs-3"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold m-0 text-dark lh-1 mb-1">4</h3>
                        <p class="text-secondary m-0 fw-semibold small">Ongoing</p>
                        <small class="text-muted fs-7">In mediation</small>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center">
                    <div class="bg-success bg-opacity-10 text-success p-3 rounded-3 me-4 d-flex align-items-center justify-content-center" style="width: 56px; height: 56px;">
                        <i class="bi bi-check2-circle fs-3"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold m-0 text-dark lh-1 mb-1">28</h3>
                        <p class="text-secondary m-0 fw-semibold small">Resolved</p>
                        <small class="text-muted fs-7">This month</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100">
                    <h5 class="fw-bold text-dark-blue mb-4 border-bottom border-light pb-2">System Features</h5>
                    <div class="row g-2">
                        <div class="col-12">
                            <div class="d-flex align-items-center py-2">
                                <i class="bi bi-check-circle-fill text-success me-3 fs-5"></i>
                                <span class="text-secondary fw-semibold">Submit Complaint Online</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center py-2">
                                <i class="bi bi-check-circle-fill text-success me-3 fs-5"></i>
                                <span class="text-secondary fw-semibold">Case Tracking System</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center py-2">
                                <i class="bi bi-check-circle-fill text-success me-3 fs-5"></i>
                                <span class="text-secondary fw-semibold">Mediation Schedule Management</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center py-2">
                                <i class="bi bi-check-circle-fill text-success me-3 fs-5"></i>
                                <span class="text-secondary fw-semibold">Resolution Monitoring</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center py-2">
                                <i class="bi bi-check-circle-fill text-success me-3 fs-5"></i>
                                <span class="text-secondary fw-semibold">Incident Reports Filing</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center py-2">
                                <i class="bi bi-check-circle-fill text-success me-3 fs-5"></i>
                                <span class="text-secondary fw-semibold">Case History Records</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="card border-0 shadow-sm p-4 rounded-3 bg-white">
                    <h5 class="fw-bold text-dark-blue mb-4 border-bottom border-light pb-2">File a Complaint</h5>

                    <form asp-controller="Modules" asp-action="ComplaintsDisputes" method="post" novalidate>
                        <div class="mb-3">
                            <label asp-for="FormModel.ComplainantName" class="form-label small fw-semibold text-secondary mb-1">Your Full Name</label>
                            <input asp-for="FormModel.ComplainantName" class="form-control bg-light border-0 py-2 px-3 rounded-2 shadow-sm text-dark fs-7" placeholder="Enter your name" />
                            <span asp-validation-for="FormModel.ComplainantName" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FormModel.RespondentName" class="form-label small fw-semibold text-secondary mb-1">Respondent / Party Involved</label>
                            <input asp-for="FormModel.RespondentName" class="form-control bg-light border-0 py-2 px-3 rounded-2 shadow-sm text-dark fs-7" placeholder="Enter respondent name" />
                            <span asp-validation-for="FormModel.RespondentName" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FormModel.ComplaintType" class="form-label small fw-semibold text-secondary mb-1">Complaint Type</label>
                            <input asp-for="FormModel.ComplaintType" class="form-control bg-light border-0 py-2 px-3 rounded-2 shadow-sm text-dark fs-7" placeholder="e.g. Noise Complaint" />
                            <span asp-validation-for="FormModel.ComplaintType" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="FormModel.Description" class="form-label small fw-semibold text-secondary mb-1">Description</label>
                            <textarea asp-for="FormModel.Description" rows="4" class="form-control bg-light border-0 py-2 px-3 rounded-2 shadow-sm text-dark fs-7" placeholder="Describe the incident..." style="resize: none;"></textarea>
                            <span asp-validation-for="FormModel.Description" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <button type="submit" class="btn text-white w-100 py-2.5 fw-bold rounded-3 shadow-sm" style="background-color: #0d2353;">
                            Submit Complaint
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm p-4 rounded-3 bg-white">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 border-bottom border-light pb-3 gap-3">
                <h5 class="fw-bold text-dark-blue m-0">Case Status Tracker</h5>
                <div class="position-relative w-100" style="max-width: 360px;">
                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted fs-6"></i>
                    <input type="text" class="form-control bg-light border-0 py-2.5 ps-5 rounded shadow-sm small" placeholder="Search case here..." />
                </div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle m-0 table-hover">
                    <thead>
                        <tr class="text-secondary small fw-bold">
                            <th class="py-3 ps-3 border-0">Case ID</th>
                            <th class="py-3 border-0">Complaint Type</th>
                            <th class="py-3 border-0">Complainant</th>
                            <th class="py-3 border-0">Date Filed</th>
                            <th class="py-3 pe-3 border-0 text-end">Status</th>
                        </tr>
                    </thead>
                    <tbody class="text-secondary fs-7">
                        @foreach (var item in Model.TrackedCases)
                        {
                            <tr class="border-bottom border-light">
                                <td class="py-3 ps-3 text-dark fw-bold">@item.CaseId</td>
                                <td class="py-3 text-dark fw-medium">@item.ComplaintType</td>
                                <td class="py-3">@item.Complainant</td>
                                <td class="py-3 text-muted">@item.DateFiled</td>
                                <td class="py-3 pe-3 text-end">
                                    @if (item.Status == "Ongoing")
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-2 rounded-pill fw-bold">Ongoing</span>
                                    }
                                    else if (item.Status == "Resolved")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill fw-bold">Resolved</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary px-3 py-2 rounded-pill fw-bold">Pending</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}