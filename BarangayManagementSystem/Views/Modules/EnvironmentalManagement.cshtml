@using BarangayManagementSystem.Models.ViewModels
@model EnvironmentalManagementPageViewModel
@{
    ViewData["Title"] = "Environmental Management";
}

<section class="hero-section text-white py-5 px-4 mb-4 shadow-sm">
    <div class="container py-2">
        <div class="d-flex align-items-center gap-3">
            <div class="p-3 bg-white bg-opacity-10 rounded-3 border border-white border-opacity-25 text-white">
                <i class="bi bi-tree fs-2"></i>
            </div>
            <div>
                <span class="badge bg-emerald text-white rounded-pill mb-1 px-3 py-1.5 fw-bold text-uppercase tracing-wider small-title-label">Module 8</span>
                <h1 class="h2 fw-bold mb-1">Environmental Management</h1>
                <p class="text-white-50 mb-0">Tracks community sanitation programs, garbage collection routes, material recovery facility counts, and local green campaigns.</p>
            </div>
        </div>
    </div>
</section>

<div class="container pb-5">

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center gap-3">
                <div class="p-3 bg-success bg-opacity-10 text-success rounded-3"><i class="bi bi-trash3 fs-3"></i></div>
                <div>
                    <h3 class="fw-bold text-dark-blue mb-0">@Model.MonthlyWasteCollected</h3>
                    <small class="text-secondary fw-semibold">Waste Segregated</small>
                    <span class="d-block text-success small-title-label mt-1">● Current Month</span>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center gap-3">
                <div class="p-3 bg-primary bg-opacity-10 text-primary rounded-3"><i class="bi bi-calendar2-week fs-3"></i></div>
                <div>
                    <h3 class="fw-bold text-dark-blue mb-0">@Model.ActiveCleanupsCount</h3>
                    <small class="text-secondary fw-semibold">Cleanup Campaigns</small>
                    <span class="d-block text-muted small-title-label mt-1">Active Projects</span>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center gap-3">
                <div class="p-3 bg-info bg-opacity-10 text-info rounded-3"><i class="bi bi-geo fs-3"></i></div>
                <div>
                    <h3 class="fw-bold text-dark-blue mb-0">@Model.MonitoredAreasCount</h3>
                    <small class="text-secondary fw-semibold">Monitored Zones</small>
                    <span class="d-block text-muted small-title-label mt-1">Sanitation Audits</span>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center gap-3">
                <div class="p-3 bg-warning bg-opacity-10 text-warning rounded-3"><i class="bi bi-people fs-3"></i></div>
                <div>
                    <h3 class="fw-bold text-dark-blue mb-0">@Model.EcoVolunteersCount</h3>
                    <small class="text-secondary fw-semibold">Green Volunteers</small>
                    <span class="d-block text-muted small-title-label mt-1">Active Roster</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100">
                <h6 class="fw-bold text-dark-blue mb-4 pb-1 border-bottom border-light">System Features</h6>
                <div class="d-flex flex-column gap-3 text-secondary">
                    @foreach (var feature in Model.SystemFeatures)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-check-circle-fill text-success"></i> <span>@feature</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-3 bg-white overflow-hidden h-100">
                <div class="p-3 border-bottom border-light">
                    <h6 class="fw-bold text-dark-blue mb-0">Garbage & Waste Collection Timetable</h6>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle text-secondary mb-0 table-hover-custom">
                        <thead class="bg-light text-dark fw-bold border-bottom">
                            <tr>
                                <th class="ps-4 py-3 fw-bold text-dark fs-7">Sector / Purok Area</th>
                                <th class="py-3 fw-bold text-dark fs-7">Collection Schedule</th>
                                <th class="pe-4 py-3 fw-bold text-dark fs-7 text-center w-150">Status</th>
                            </tr>
                        </thead>
                        <tbody class="border-top-0">
                            @foreach (var route in Model.CollectionSchedules)
                            {
                                <tr>
                                    <td class="ps-4 py-3">
                                        <span class="text-dark fw-bold d-block">@route.ZoneOrPurok</span>
                                        <small class="text-muted font-monospace" style="font-size: 0.75rem;"><i class="bi bi-recycle"></i> @route.WasteType</small>
                                    </td>
                                    <td class="py-3 text-dark fw-semibold">@route.CollectionDay</td>
                                    <td class="pe-4 py-3 text-center">
                                        @if (route.Status == "Scheduled")
                                        {
                                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-1.5 fs-8">Scheduled</span>
                                        }
                                        else if (route.Status == "Completed")
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1.5 fs-8">Completed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3 py-1.5 fs-8">Delayed</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>