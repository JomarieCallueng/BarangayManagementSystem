<div class="container-fluid px-0 pb-5">

    <div class="hero-section text-white py-5 px-4 px-md-5 mb-5 shadow-sm bg-dark-blue mt-0">
        <div class="d-flex align-items-center">
            <div class="bg-white bg-opacity-10 p-3 rounded-3 me-3 d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                <i class="bi bi-file-earmark-text fs-2"></i>
            </div>
            <div>
                <span class="badge bg-warning text-dark mb-1 fw-bold text-uppercase px-2 py-1 fs-8">Module 2</span>
                <h2 class="fw-bold m-0 tracking-tight">Certificates and Permits Management</h2>
                <p class="text-white-50 m-0 small mt-1">Automates the request and issuance of barangay certificates and permits.</p>
            </div>
        </div>
    </div>

    <div class="px-4 px-md-5">

        <div class="row g-4 mb-4">
            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center">
                    <div class="bg-warning bg-opacity-10 text-warning p-3 rounded-3 me-4 d-flex align-items-center justify-content-center" style="width: 56px; height: 56px;">
                        <i class="bi bi-clock-history fs-3"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold m-0 text-dark lh-1 mb-1">12</h3>
                        <p class="text-secondary m-0 fw-semibold small">Pending</p>
                        <small class="text-muted fs-7">Awaiting action</small>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center">
                    <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-3 me-4 d-flex align-items-center justify-content-center" style="width: 56px; height: 56px;">
                        <i class="bi bi-box-seam fs-3"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold m-0 text-dark lh-1 mb-1">8</h3>
                        <p class="text-secondary m-0 fw-semibold small">Processing</p>
                        <small class="text-muted fs-7">In progress</small>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center">
                    <div class="bg-success bg-opacity-10 text-success p-3 rounded-3 me-4 d-flex align-items-center justify-content-center" style="width: 56px; height: 56px;">
                        <i class="bi bi-check2-square fs-3"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold m-0 text-dark lh-1 mb-1">5</h3>
                        <p class="text-secondary m-0 fw-semibold small">Ready</p>
                        <small class="text-muted fs-7">For release</small>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center">
                    <div class="bg-info bg-opacity-10 text-info p-3 rounded-3 me-4 d-flex align-items-center justify-content-center" style="width: 56px; height: 56px;">
                        <i class="bi bi-truck fs-3"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold m-0 text-dark lh-1 mb-1">143</h3>
                        <p class="text-secondary m-0 fw-semibold small">Released</p>
                        <small class="text-muted fs-7">This month</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100">
                    <h5 class="fw-bold text-dark-blue mb-4 border-bottom border-light pb-2">Available Document Types</h5>
                    <div class="row g-2">
                        <div class="col-12">
                            <div class="d-flex align-items-center py-2">
                                <i class="bi bi-check-circle-fill text-success me-3 fs-5"></i>
                                <span class="text-secondary fw-semibold">Barangay Clearance</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center py-2">
                                <i class="bi bi-check-circle-fill text-success me-3 fs-5"></i>
                                <span class="text-secondary fw-semibold">Residency Certificate</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center py-2">
                                <i class="bi bi-check-circle-fill text-success me-3 fs-5"></i>
                                <span class="text-secondary fw-semibold">Good Moral Certificate</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center py-2">
                                <i class="bi bi-check-circle-fill text-success me-3 fs-5"></i>
                                <span class="text-secondary fw-semibold">Business Permit</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center py-2">
                                <i class="bi bi-check-circle-fill text-success me-3 fs-5"></i>
                                <span class="text-secondary fw-semibold">Facility Use Permit</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="card border-0 shadow-sm p-4 rounded-3 bg-white">
                    <h5 class="fw-bold text-dark-blue mb-4 border-bottom border-light pb-2">Certificate Request Form</h5>

                    <form asp-controller="Modules" asp-action="SubmitCertificateRequest" method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-semibold text-secondary mb-1">Full Name</label>
                            <input type="text" class="form-control bg-light border-0 py-2 px-3 rounded-2 shadow-sm" placeholder="Enter full name" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-semibold text-secondary mb-1">Purpose</label>
                            <input type="text" class="form-control bg-light border-0 py-2 px-3 rounded-2 shadow-sm" placeholder="Enter purpose" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-semibold text-secondary mb-1">Contact Number</label>
                            <input type="tel" class="form-control bg-light border-0 py-2 px-3 rounded-2 shadow-sm" placeholder="09XX-XXX-XXXX" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-semibold text-secondary mb-1">Type of Certificate</label>
                            <select class="form-select bg-light border-0 py-2 px-3 rounded-2 text-secondary shadow-sm" required>
                                <option value="" disabled selected>Select type...</option>
                                <option value="BarangayClearance">Barangay Clearance</option>
                                <option value="ResidencyCertificate">Residency Certificate</option>
                                <option value="GoodMoralCertificate">Good Moral Certificate</option>
                                <option value="BusinessPermit">Business Permit</option>
                                <option value="FacilityUsePermit">Facility Use Permit</option>
                            </select>
                        </div>

                        <button type="submit" class="btn text-white w-100 py-2.5 fw-bold rounded-3 shadow-sm" style="background-color: #0d2353;">
                            Submit Request
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm p-4 rounded-3 bg-white">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 border-bottom border-light pb-3 gap-3">
                <h5 class="fw-bold text-dark-blue m-0">Request Status Tracker</h5>
                <div class="position-relative w-100" style="max-width: 360px;">
                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted fs-6"></i>
                    <input type="text" class="form-control bg-light border-0 py-2.5 ps-5 rounded shadow-sm small" placeholder="Search request here..." />
                </div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle m-0 table-hover">
                    <thead>
                        <tr class="text-secondary small fw-bold">
                            <th class="py-3 ps-3 border-0">Request ID</th>
                            <th class="py-3 border-0">Resident Name</th>
                            <th class="py-3 border-0">Certificate Type</th>
                            <th class="py-3 border-0">Purpose</th>
                            <th class="py-3 pe-3 border-0 text-end">Status</th>
                        </tr>
                    </thead>
                    <tbody class="text-secondary fs-7">
                        <tr class="border-bottom border-light">
                            <td class="py-3 ps-3 text-dark fw-bold">REQ-2026-001</td>
                            <td class="py-3 text-dark fw-medium">Juan Dela Cruz</td>
                            <td class="py-3">Barangay Clearance</td>
                            <td class="py-3 text-muted">Employment Requirement</td>
                            <td class="py-3 pe-3 text-end">
                                <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill fw-bold">Ready for Release</span>
                            </td>
                        </tr>
                        <tr class="border-bottom border-light">
                            <td class="py-3 ps-3 text-dark fw-bold">REQ-2026-002</td>
                            <td class="py-3 text-dark fw-medium">Maria Santos</td>
                            <td class="py-3">Business Permit</td>
                            <td class="py-3 text-muted">Sari-Sari Store Registration</td>
                            <td class="py-3 pe-3 text-end">
                                <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-2 rounded-pill fw-bold">Processing</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>