@model BarangayManagementSystem.Models.BudgetProjectsPageViewModel
@{
    ViewData["Title"] = "Budget & Project Monitoring";
}

<section class="hero-section text-white py-5 px-4 mb-4 shadow-sm">
    <div class="container py-2">
        <div class="d-flex align-items-center gap-3">
            <div class="p-3 bg-white bg-opacity-10 rounded-3 border border-white border-opacity-25 text-white">
                <i class="bi bi-wallet2 fs-2"></i>
            </div>
            <div>
                <span class="badge bg-emerald text-white rounded-pill mb-1 px-3 py-1.5 fw-bold text-uppercase tracing-wider small-title-label">Module 5</span>
                <h1 class="h2 fw-bold mb-1">Budget & Project Monitoring</h1>
                <p class="text-white-50 mb-0">Provides tracking of barangay financial allocations, expenditures, and development projects.</p>
            </div>
        </div>
    </div>
</section>

<div class="container pb-5">

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center gap-3">
                <div class="p-3 bg-primary bg-opacity-10 text-primary rounded-3"><i class="bi bi-cash-coin fs-3"></i></div>
                <div>
                    <h3 class="fw-bold text-dark-blue mb-0">@Model.TotalBudgetFormatted</h3>
                    <small class="text-secondary fw-semibold">Total Budget Allocated</small>
                    <span class="d-block text-muted small-title-label mt-1">Annual Fiscal Year</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center gap-3">
                <div class="p-3 bg-danger bg-opacity-10 text-danger rounded-3"><i class="bi bi-pie-chart fs-3"></i></div>
                <div>
                    <h3 class="fw-bold text-dark-blue mb-0">@Model.UtilizedAmountFormatted</h3>
                    <small class="text-secondary fw-semibold">Utilized Budget (@Model.UtilizationPercentage%)</small>
                    <div class="progress mt-2" style="height: 6px; width: 150px;">
                        <div class="progress-bar bg-danger" role="progressbar" style="width: @Model.UtilizationPercentage%" aria-valuenow="@Model.UtilizationPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100 d-flex flex-row align-items-center gap-3">
                <div class="p-3 bg-success bg-opacity-10 text-success rounded-3"><i class="bi bi-diagram-3 fs-3"></i></div>
                <div>
                    <h3 class="fw-bold text-dark-blue mb-0">@Model.ActiveProjectsCount / @(Model.ActiveProjectsCount + Model.CompletedProjectsCount + 1)</h3>
                    <small class="text-secondary fw-semibold">Active Development Projects</small>
                    <span class="d-block text-success small-title-label mt-1">● Ongoing Tasks</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100">
                <h6 class="fw-bold text-dark-blue mb-4 pb-1 border-bottom border-light">System Features</h6>
                <div class="d-flex flex-column gap-3 text-secondary">
                    @foreach (var feature in Model.SystemFeatures)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-check-circle-fill text-success"></i> <span>@feature</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100">
                <h6 class="fw-bold text-dark-blue mb-4 pb-1 border-bottom border-light">Budget Allocation Summary</h6>
                <div class="d-flex flex-column gap-4">
                    @foreach (var alloc in Model.Allocations)
                    {
                        <div>
                            <div class="d-flex justify-content-between small fw-semibold text-secondary mb-1">
                                <span>@alloc.Category</span>
                                <span class="text-dark-blue">₱@alloc.Amount.ToString("N0")</span>
                            </div>
                            <div class="progress bg-light rounded-pill" style="height: 8px;">
                                <div class="progress-bar bg-primary rounded-pill" role="progressbar" style="width: 45%" aria-valuenow="45" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 bg-white overflow-hidden">
        <div class="p-3 border-bottom border-light">
            <h6 class="fw-bold text-dark-blue mb-0">Project Progress Tracker</h6>
        </div>
        <div class="table-responsive">
            <table class="table align-middle text-secondary mb-0 table-hover-custom">
                <thead class="bg-light text-dark fw-bold border-bottom">
                    <tr>
                        <th class="ps-4 py-3 fw-bold text-dark fs-7">Project Name</th>
                        <th class="py-3 fw-bold text-dark fs-7">Budget Allocated</th>
                        <th class="py-3 fw-bold text-dark fs-7 w-200">Progress Bar</th>
                        <th class="pe-4 py-3 fw-bold text-dark fs-7 text-center w-150">Status</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var project in Model.Projects)
                    {
                        <tr>
                            <td class="ps-4 py-3 text-dark fw-bold">@project.Name</td>
                            <td class="py-3 text-muted">₱@project.Budget.ToString("N0")</td>
                            <td class="py-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress bg-light flex-grow-1" style="height: 6px;">
                                        <div class="progress-bar bg-success" role="progressbar" style="width: @project.ProgressPercentage%" aria-valuenow="@project.ProgressPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <small class="text-secondary font-monospace">@project.ProgressPercentage%</small>
                                </div>
                            </td>
                            <td class="pe-4 py-3 text-center">
                                @if (project.Status == "Completed")
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1.5 fs-8">Completed</span>
                                }
                                else if (project.Status == "Ongoing")
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-1.5 fs-8">Ongoing</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3 py-1.5 fs-8">Pending</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>