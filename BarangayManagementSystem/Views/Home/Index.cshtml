@{
    ViewData["Title"] = "Home";
}

<section class="hero-section text-center text-white py-5 px-3">
    <div class="container py-4">
        <span class="badge rounded-pill bg-white bg-opacity-10 text-white border border-white border-opacity-25 mb-3 px-3 py-2 small"><i class="bi bi-shield-fill me-1"></i> Digital Barangay Governance Platform</span>
        <h1 class="display-5 fw-bold mb-3 px-md-5">Komprehensibong Sistema ng Pamamahala at Pagbibigay ng Serbisyo para sa Barangay</h1>
        <p class="lead text-white-50 mx-auto mb-4 fs-6 modern-max-width">A centralized digital platform designed to improve governance, public service delivery, disaster preparedness, health services, and environmental management within the barangay.</p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Modules" asp-action="ResidentInformation" class="btn btn-light px-4 py-2 fw-semibold text-decoration-none">Get Started <i class="bi bi-chevron-right small ms-1"></i></a>
            <button class="btn btn-outline-light px-4 py-2 bg-white bg-opacity-10">View Services</button>

            <a asp-controller="Modules" asp-action="Announcements" fragment="emergency-section" class="btn btn-success bg-emerald px-4 py-2 fw-semibold text-white text-decoration-none">
                Emergency Contacts
            </a>
        </div>
    </div>
</section>

<section class="bg-white border-bottom py-4 shadow-sm">
    <div class="container">
        <div class="row text-center g-3">
            <div class="col-6 col-md-3">
                <h3 class="fw-bold text-dark-blue mb-0">8</h3>
                <small class="text-muted">Service Modules</small>
            </div>
            <div class="col-6 col-md-3">
                <h3 class="fw-bold text-dark-blue mb-0">1,250+</h3>
                <small class="text-muted">Registered Residents</small>
            </div>
            <div class="col-6 col-md-3">
                <h3 class="fw-bold text-dark-blue mb-0">3</h3>
                <small class="text-muted">Evacuation Centers</small>
            </div>
            <div class="col-6 col-md-3">
                <h3 class="fw-bold text-dark-blue mb-0">24/7</h3>
                <small class="text-muted">Emergency Line</small>
            </div>
        </div>
    </div>
</section>

<section class="container py-5 mt-3">
    <div class="row g-5 align-items-center">
        <div class="col-lg-6">
            <small class="text-success text-uppercase fw-bold tracking-wider d-block mb-2">About the System</small>
            <h2 class="fw-bold text-dark-blue mb-3">Isang Integrated Digital Platform para sa Barangay</h2>
            <p class="text-secondary mb-3">Ang sistemang ito ay isang integrated digital platform na ginawa upang mapabilis, mapadali, at mapahusay ang mga operasyon at serbisyo ng barangay.</p>
            <p class="text-secondary mb-4">Layunin nitong gawing mas organisado ang records management, public service delivery, communication, at emergency response upang mas mapagsilbihan nang maayos ang mga mamamayan.</p>

            <ul class="list-unstyled space-y-2">
                <li class="d-flex align-items-start mb-2"><i class="bi bi-check-circle-fill text-success me-2 mt-1"></i> <span>Streamlined records management for all residents</span></li>
                <li class="d-flex align-items-start mb-2"><i class="bi bi-check-circle-fill text-success me-2 mt-1"></i> <span>Fast and transparent public service delivery</span></li>
                <li class="d-flex align-items-start mb-2"><i class="bi bi-check-circle-fill text-success me-2 mt-1"></i> <span>Real-time emergency alerts and communication</span></li>
                <li class="d-flex align-items-start"><i class="bi bi-check-circle-fill text-success me-2 mt-1"></i> <span>Accountable budget and project monitoring</span></li>
            </ul>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white">
                <div class="d-flex align-items-center mb-4">
                    <div class="p-3 bg-light rounded-3 text-dark-blue me-3"><i class="bi bi-building fs-3"></i></div>
                    <div>
                        <h5 class="fw-bold mb-0">Barangay Hall</h5>
                        <small class="text-muted">Official Barangay Address Here</small>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-borderless align-middle mb-0 text-secondary small">
                        <tr><td class="ps-0 py-2">Office Hours</td><td class="text-end fw-bold text-dark">Mon–Fri, 8AM–5PM</td></tr>
                        <tr class="border-top"><td class="ps-0 py-2">Emergency Hotline</td><td class="text-end fw-bold text-dark">0912-345-6789</td></tr>
                        <tr class="border-top"><td class="ps-0 py-2">Email</td><td class="text-end fw-bold text-dark">barangay@email.com</td></tr>
                        <tr class="border-top"><td class="ps-0 py-2">Services</td><td class="text-end fw-bold text-dark">8 Modules</td></tr>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="bg-light py-5">
    <div class="container text-center">
        <small class="text-success text-uppercase fw-bold tracking-wider">Core Features</small>
        <h2 class="fw-bold text-dark-blue mb-2">Complete Service Modules</h2>
        <p class="text-muted mb-5">All 8 barangay service modules in one integrated system.</p>

        <div class="row g-4 text-start">

            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm p-4 rounded-3 backend-card">
                    <div class="icon-box bg-primary bg-opacity-10 text-primary mb-3"><i class="bi bi-people fs-4"></i></div>
                    <h6 class="fw-bold text-dark">Resident Information Management</h6>
                    <p class="text-muted small">Manage resident database, family records, and population statistics.</p>
                    <ul class="list-unstyled small text-secondary mb-4 mt-auto">
                        <li><span class="text-success me-1">•</span> Resident Database</li>
                        <li><span class="text-success me-1">•</span> Family Records</li>
                        <li><span class="text-success me-1">•</span> Population Statistics</li>
                    </ul>
                    <a asp-controller="Modules" asp-action="ResidentInformation" class="text-primary fw-semibold small text-decoration-none mt-2">View Module &rarr;</a>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm p-4 rounded-3 backend-card">
                    <div class="icon-box bg-purple bg-opacity-10 text-purple mb-3"><i class="bi bi-file-earmark-text fs-4"></i></div>
                    <h6 class="fw-bold text-dark">Certificates and Permits</h6>
                    <p class="text-muted small">Automate issuance of barangay certificates and permits.</p>
                    <ul class="list-unstyled small text-secondary mb-4 mt-auto">
                        <li><span class="text-success me-1">•</span> Barangay Clearance</li>
                        <li><span class="text-success me-1">•</span> Business Permit</li>
                        <li><span class="text-success me-1">•</span> Residency Certificate</li>
                    </ul>
                    <a asp-controller="Modules" asp-action="CertificatesPermits" class="text-primary fw-semibold small text-decoration-none mt-2">View Module &rarr;</a>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm p-4 rounded-3 backend-card">
                    <div class="icon-box bg-warning bg-opacity-10 text-warning mb-3"><i class="bi bi-chat-left-text fs-4"></i></div>
                    <h6 class="fw-bold text-dark">Complaints and Dispute Resolution</h6>
                    <p class="text-muted small">Record and track complaints, incidents, and disputes.</p>
                    <ul class="list-unstyled small text-secondary mb-4 mt-auto">
                        <li><span class="text-success me-1">•</span> Complaint Filing</li>
                        <li><span class="text-success me-1">•</span> Case Tracking</li>
                        <li><span class="text-success me-1">•</span> Settlement Monitoring</li>
                    </ul>
                    <a asp-controller="Modules" asp-action="ComplaintsDisputes" class="text-primary fw-semibold small text-decoration-none mt-2">View Module &rarr;</a>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm p-4 rounded-3 backend-card">
                    <div class="icon-box bg-danger bg-opacity-10 text-danger mb-3"><i class="bi bi-bell fs-4"></i></div>
                    <h6 class="fw-bold text-dark">Information Dissemination</h6>
                    <p class="text-muted small">Fast dissemination of emergency alerts and announcements.</p>
                    <ul class="list-unstyled small text-secondary mb-4 mt-auto">
                        <li><span class="text-success me-1">•</span> Emergency Alerts</li>
                        <li><span class="text-success me-1">•</span> Barangay Announcements</li>
                        <li><span class="text-success me-1">•</span> SMS Notifications</li>
                    </ul>
                    <a asp-controller="Modules" asp-action="Announcements" class="text-primary fw-semibold small text-decoration-none mt-2">View Module &rarr;</a>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm p-4 rounded-3 backend-card">
                    <div class="icon-box bg-info bg-opacity-10 text-info mb-3"><i class="bi bi-bar-chart fs-4"></i></div>
                    <h6 class="fw-bold text-dark">Budget and Project Management</h6>
                    <p class="text-muted small">Track barangay projects, expenses, and fund allocation.</p>
                    <ul class="list-unstyled small text-secondary mb-4 mt-auto">
                        <li><span class="text-success me-1">•</span> Budget Allocation</li>
                        <li><span class="text-success me-1">•</span> Expense Monitoring</li>
                        <li><span class="text-success me-1">•</span> Project Tracking</li>
                    </ul>
                    <a asp-controller="Modules" asp-action="BudgetProjects" class="text-primary fw-semibold small text-decoration-none mt-2">View Module &rarr;</a>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm p-4 rounded-3 backend-card">
                    <div class="icon-box bg-warning bg-opacity-10 text-dark mb-3"><i class="bi bi-exclamation-triangle fs-4"></i></div>
                    <h6 class="fw-bold text-dark">Disaster Preparedness and Response</h6>
                    <p class="text-muted small">Improve emergency preparedness and disaster response management.</p>
                    <ul class="list-unstyled small text-secondary mb-4 mt-auto">
                        <li><span class="text-success me-1">•</span> Evacuation Centers</li>
                        <li><span class="text-success me-1">•</span> Relief Goods Inventory</li>
                        <li><span class="text-success me-1">•</span> Hazard Mapping</li>
                    </ul>
                    <a asp-controller="Modules" asp-action="DisasterPreparedness" class="text-primary fw-semibold small text-decoration-none mt-2">View Module &rarr;</a>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm p-4 rounded-3 backend-card">
                    <div class="icon-box bg-danger bg-opacity-10 text-danger mb-3"><i class="bi bi-heart fs-4"></i></div>
                    <h6 class="fw-bold text-dark">Health and Welfare Services</h6>
                    <p class="text-muted small">Monitor community health programs and welfare initiatives.</p>
                    <ul class="list-unstyled small text-secondary mb-4 mt-auto">
                        <li><span class="text-success me-1">•</span> Vaccination Records</li>
                        <li><span class="text-success me-1">•</span> Medical Assistance</li>
                        <li><span class="text-success me-1">•</span> Senior Citizen Services</li>
                    </ul>
                    <a asp-controller="Modules" asp-action="HealthWelfare" class="text-primary fw-semibold small text-decoration-none mt-2">View Module &rarr;</a>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm p-4 rounded-3 backend-card">
                    <div class="icon-box bg-success bg-opacity-10 text-success mb-3"><i class="bi bi-leaf fs-4"></i></div>
                    <h6 class="fw-bold text-dark">Environmental Management</h6>
                    <p class="text-muted small">Support environmental protection and cleanliness initiatives.</p>
                    <ul class="list-unstyled small text-secondary mb-4 mt-auto">
                        <li><span class="text-success me-1">•</span> Garbage Collection</li>
                        <li><span class="text-success me-1">•</span> Clean-up Drives</li>
                        <li><span class="text-success me-1">•</span> Waste Segregation</li>
                    </ul>
                    <a asp-controller="Modules" asp-action="EnvironmentalManagement" class="text-primary fw-semibold small text-decoration-none mt-2">View Module &rarr;</a>
                </div>
            </div>

        </div>
    </div>
</section>