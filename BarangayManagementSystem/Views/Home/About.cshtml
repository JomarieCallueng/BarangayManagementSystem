@{
    ViewData["Title"] = "About Our Barangay";
}

<section class="hero-section text-white py-5 px-4 mb-5 shadow-sm">
    <div class="container py-2">
        <div class="d-flex align-items-center gap-3">
            <div class="p-3 bg-white bg-opacity-10 rounded-3 border border-white border-opacity-25">
                <i class="bi bi-info-circle fs-2"></i>
            </div>
            <div>
                <h1 class="h2 fw-bold mb-1">About Our Barangay</h1>
                <p class="text-white-50 mb-0">Learn about our history, organizational goals, core public values, and the community structures.</p>
            </div>
        </div>
    </div>
</section>

<div class="container pb-5">
    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100">
                <h5 class="fw-bold text-dark-blue mb-3"><i class="bi bi-eye text-primary me-2"></i>Our Vision</h5>
                <p class="text-secondary small lh-base">To build a safe, progressive, climate-resilient, and united barangay that promotes sustainable economic development, equal public healthcare opportunities, and innovative community infrastructure frameworks driven by digitalized data automation systems.</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white h-100">
                <h5 class="fw-bold text-dark-blue mb-3"><i class="bi bi-flag text-success me-2"></i>Our Mission</h5>
                <p class="text-secondary small lh-base">To deliver accessible and accurate public welfare services, transparent budget administration reporting, swift disaster risk management reactions, and strong legal support platforms for the common good of all registered families within our territory.</p>
            </div>
        </div>
    </div>

    <!-- History Block -->
    <div class="card border-0 shadow-sm p-4 rounded-3 bg-white mb-5">
        <h5 class="fw-bold text-dark-blue mb-3"><i class="bi bi-hourglass-split text-warning me-2"></i>Historical Background</h5>
        <p class="text-secondary small lh-lg">Established as a small traditional settlement centuries ago, our locality has evolved organically into a booming administrative territory. Guided by progressive local leaders and highly cooperative structural sub-committees, the community remains unified in maintaining safe urban development while strictly honoring legacy regional customs and inclusive community values.</p>
    </div>
</div>