@{
    ViewData["Title"] = "Processing Fees";
}

<section class="hero-section text-white py-5 px-4 mb-5 shadow-sm">
    <div class="container py-2">
        <div class="d-flex align-items-center gap-3">
            <div class="p-3 bg-white bg-opacity-10 rounded-3 border border-white border-opacity-25">
                <i class="bi bi-cash-coin fs-2"></i>
            </div>
            <div>
                <h1 class="h2 fw-bold mb-1">Document Fees Schedule</h1>
                <p class="text-white-50 mb-0">Transparent reference for standard document costs as per the unified revenue tax ordinance.</p>
            </div>
        </div>
    </div>
</section>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-4 rounded-3 bg-white">
                <h5 class="fw-bold text-dark-blue mb-4">Official Rate Sheets</h5>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 text-secondary">
                        <thead class="table-light">
                            <tr class="text-dark-blue fw-bold">
                                <th>Document Type</th>
                                <th class="text-end">Standard Rate</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="border-bottom-gray">
                                <td class="py-3">Barangay Clearance (Local Employment)</td>
                                <td class="text-end fw-bold text-dark-blue">₱50.00</td>
                            </tr>
                            <tr class="border-bottom-gray">
                                <td class="py-3">Barangay Clearance (Abroad/Passport)</td>
                                <td class="text-end fw-bold text-dark-blue">₱100.00</td>
                            </tr>
                            <tr class="border-bottom-gray">
                                <td class="py-3">Certificate of Residency</td>
                                <td class="text-end fw-bold text-dark-blue">₱30.00</td>
                            </tr>
                            <tr class="border-bottom-gray">
                                <td class="py-3">Business Permit Clearance</td>
                                <td class="text-end fw-bold text-dark-blue">₱500.00</td>
                            </tr>
                            <tr>
                                <td class="py-3 text-success font-semibold">Certificate of Indigency</td>
                                <td class="text-end fw-bold text-success">FREE / WAIVED</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="bg-light p-3 rounded-3 mt-4 text-muted small">
                    <i class="bi bi-exclamation-circle-fill me-1 text-primary"></i> Payment tracking numbers are automatically sent back via local message relays after an online request is formally validated by administrative officers.
                </div>
            </div>
        </div>
    </div>
</div>